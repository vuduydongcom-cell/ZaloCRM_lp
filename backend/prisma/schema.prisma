// ════════════════════════════════════════════════════════════════════════

// ════════════════════════════════════════════════════════════════════════
// AutomationEventLog — Luồng Mục Tiêu M3 (2026-06-01)
// ════════════════════════════════════════════════════════════════════════
// Append-only event log:
//   1. Outbox sweeper recovery (v4 Fix #1): check sequence_step_sent ↔
//      sequence_step_enqueued chain consistency
//   2. Stats Dashboard M10: count event by type per trigger
//   3. M5 pause/resume: latest event per (trigger, contact)
//
// Event types:
//   sequence_step_enqueued | sequence_step_sent | sequence_step_failed
//   friend_request_sent | friend_accepted | friend_rejected | friend_blocked
//   customer_reply | customer_block | customer_reaction_negative
//   manual_pause | manual_stop | manual_resume | manual_enroll
//   no_zalo | send_error | nick_disconnected
//
// Migration: 20260601193019_automation_event_log
model AutomationEventLog {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  // Wave 3 (2026-05-30): triggerId required cho timeline UI Mục tiêu Detail.
  // Luồng Mục Tiêu M3 (2026-06-01): optional cho manual events.
  triggerId     String?  @map("trigger_id")
  // Wave 3 fields cho audit task lifecycle
  taskId        String?  @map("task_id")
  contactId     String?  @map("contact_id")
  nickId        String?  @map("nick_id")
  eventType     String   @map("event_type")
  // Wave 3: info | warning | urgent — UI tô màu chip + sort order trong timeline
  eventPriority String   @default("info") @map("event_priority")
  // Wave 3 dùng summary (rich text); Luồng Mục Tiêu M3 dùng detail (shorter).
  // Cả hai cùng tồn tại để backward compat — code mới dùng detail, code Wave 3 dùng summary.
  summary       String?  @db.Text
  detail        String?
  // 2026-06-18 Observability "vì sao không gửi": phân loại blocker (quota_message_exhausted,
  // quota_friend_exhausted, outside_hour_window, nick_offline, sequence_disabled...) để lọc
  // nhanh + tách "hết quota tin" khỏi lỗi gửi thường (eventType quá chung). NULL cho event cũ.
  category      String?  @map("category")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Luồng Mục Tiêu M3 indexes
  @@index([triggerId, contactId, eventType], map: "idx_automation_event_log_trigger_contact_type")
  // 2026-06-18 Observability: lọc theo lý do (category) trong 1 trigger
  @@index([triggerId, category, createdAt(sort: Desc)], map: "idx_event_log_trigger_category_time")
  @@index([eventType, createdAt(sort: Desc)], map: "idx_automation_event_log_type_created")
  @@index([orgId, eventType, createdAt(sort: Desc)], map: "idx_automation_event_log_org_type_created")
  @@index([contactId, createdAt(sort: Desc)], map: "idx_automation_event_log_contact_created")
  // Wave 3 indexes
  @@index([triggerId, createdAt(sort: Desc)], map: "idx_event_log_trigger_time")
  @@index([orgId, createdAt(sort: Desc)], map: "idx_event_log_org_time")
  @@index([eventType], map: "idx_event_log_type")
  @@map("automation_event_log")
}

// ════════════════════════════════════════════════════════════════════════
// Phase 8 — ContactEngagementDaily
// ════════════════════════════════════════════════════════════════════════
// 1 row per (Contact × date). Aggregate per-day engagement signals cho
// heatmap UI 4-week timeline + pattern classification (hot/champion/etc).
//
// Write path:
//   - Real-time: message-handler hook (incrementDailyAggregate) on every
//     inbound/outbound message + reaction event. Upsert today's row.
//   - Daily 02:30 VN cron: recompute Contact.engagementPattern/Trend dựa
//     trên 28-day window, cleanup rows >12 tuần (rolling).
//
// Read path:
//   - GET /api/v1/contacts/:id/engagement-timeline → return 28 days
//   - Filter: conversation list lọc theo Contact.engagementPattern
//
// Daily intensity formula (capped 0-100):
//   30 × reaction + 30 × voiceMsg + 20 × customerInitiated +
//   15 × mediaShare + 5 × inbound + 5 × outbound (with seen)
model ContactEngagementDaily {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  contactId String   @map("contact_id")
  date      DateTime @db.Date

  // Aggregates per day
  inboundMsgCount   Int     @default(0) @map("inbound_msg_count")
  outboundMsgCount  Int     @default(0) @map("outbound_msg_count")
  reactionCount     Int     @default(0) @map("reaction_count") // KH reaction trên tin sale
  mediaShareCount   Int     @default(0) @map("media_share_count") // KH gửi ảnh/video/file/voice/location/...
  voiceMsgCount     Int     @default(0) @map("voice_msg_count") // KH gửi voice (subset của media)
  callCount         Int     @default(0) @map("call_count") // KH gọi voice/video — duration > 0 (connected)
  missedCallCount   Int     @default(0) @map("missed_call_count") // KH gọi nhỡ — duration = 0 (intent yếu hơn)
  quoteReplyCount   Int     @default(0) @map("quote_reply_count") // KH quote-reply 1 tin của sale (signal mạnh)
  customerInitiated Boolean @default(false) @map("customer_initiated") // KH nhắn trước trong ngày

  // Derived intensity 0-100 (heatmap cell color)
  dailyIntensity Int @default(0) @map("daily_intensity")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([orgId, contactId, date])
  @@index([orgId, contactId, date(sort: Desc)])
  @@index([orgId, date])
  @@map("contact_engagement_daily")
}

// ════════════════════════════════════════════════════════════════════════
// Tệp khách hàng (Customer Lists) — Phase 7 audience layer
// ════════════════════════════════════════════════════════════════════════
// Sale paste/upload danh sách SĐT → CustomerList row + N CustomerListEntry
// rows. Enrichment async qua background worker + Phase 7 event bus.
//
// Reverse-update từ 3 nguồn (qua Phase 7 automationEventBus + phone_uid_resolved
// event mới):
//   1. campaign action handler request-friend → findUserByPhone resolved
//   2. nick friend-sync alias-sync → Friend.phoneNormalized match contact
//   3. Contact create với phone → check Friend table có nick nào friend
//
// Sequence/Broadcast/Campaign future feature reference customerListId làm
// audience source.
model CustomerList {
  id          String  @id @default(uuid())
  orgId       String  @map("org_id")
  createdById String  @map("created_by_id")
  name        String
  iconEmoji   String? @map("icon_emoji") // optional emoji prefix (🏢, 📣, ❄️...)
  sourceType  String  @map("source_type") // 'paste' | 'csv' | 'excel' | 'api'
  rawText     String? @map("raw_text") @db.Text // gốc để rerun parser/audit

  // Stats counters — update qua reverse hook khi entries change
  totalEntries          Int @default(0) @map("total_entries")
  validEntries          Int @default(0) @map("valid_entries")
  invalidEntries        Int @default(0) @map("invalid_entries")
  dupInListEntries      Int @default(0) @map("dup_in_list_entries")
  dupCrossListEntries   Int @default(0) @map("dup_cross_list_entries")
  dupWithContactEntries Int @default(0) @map("dup_with_contact_entries")
  hasZaloEntries        Int @default(0) @map("has_zalo_entries")
  noZaloEntries         Int @default(0) @map("no_zalo_entries")
  pendingLookupEntries  Int @default(0) @map("pending_lookup_entries")

  // Lifecycle: 'processing' | 'done' | 'archived'
  status     String    @default("processing")
  startedAt  DateTime  @default(now()) @map("started_at")
  endedAt    DateTime? @map("ended_at")
  archivedAt DateTime? @map("archived_at")

  // Phase Lead Pool 2026-05-24 — admin tick để mở list cho sale tự nhận lead.
  // Default false (admin chủ động share). Khi true, các entry validated trong list này
  // vào pool /lead-pool/request với source='customer_list'.
  shareableToPool Boolean @default(false) @map("shareable_to_pool")

  // Phase Multi-Source Lead Ads 2026-05-27 — gắn key in tên campaign (#A-001) cho
  // routing tự động. Unique per org để parser map campaignName → list_id.
  // displayInlineFields = mảng tên customFields hiển thị inline trong ListDetailView.
  integrationKey      String? @map("integration_key")
  displayInlineFields Json?   @map("display_inline_fields")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entries              CustomerListEntry[]
  // Phase FB Lead Ads "Form" 2026-06-09 — map form→list + round-robin sale assignment.
  facebookFormMappings FacebookFormMapping[]
  saleAssignments      CustomerListSaleAssignment[]
  assignmentState      SaleAssignmentState?

  @@unique([orgId, integrationKey])
  @@index([orgId, status, createdAt(sort: Desc)])
  @@index([orgId, archivedAt])
  @@map("customer_lists")
}

model CustomerListEntry {
  id             String       @id @default(uuid())
  customerListId String       @map("customer_list_id")
  customerList   CustomerList @relation(fields: [customerListId], references: [id], onDelete: Cascade)

  rowIndex Int @map("row_index") // 1-based, original order in paste

  // Raw input
  phoneRaw String  @map("phone_raw") // gốc anh paste vào
  nameRaw  String? @map("name_raw") // cắt ra từ phoneRaw nếu có

  // Lời mời / tin nhắn riêng cho entry này — dùng khi gửi friend-request hoặc message
  // Chỉ map từ CSV/Excel column "Ghi chú". Paste tab KHÔNG có (chỉ phone+name).
  // Tên field cố ý KHÔNG là `notes` để tránh nhầm với Contact.notes (CRM internal notes).
  personalNote String? @map("personal_note")

  // 2026-05-20: 2-axis status refactor.
  // Lifecycle (5 state) đọc từ `status` + `hasZalo`:
  //   Mới — entry vừa insert (status=pending/validated, chưa qua worker)
  //   Đang chờ Quét — đã validate hoặc Friend check no-match (status=validated|enriched + hasZalo=null)
  //   Có Zalo — hasZalo=true
  //   Không có Zalo — hasZalo=false (CHỈ Campaign SDK 404 confirm)
  //   Lỗi — status=invalid (parse fail)
  //
  // systemMessages = append-only stack các sự kiện đặc thù (trùng list X, đã CRM,
  // sale loại, số sai format cụ thể, ...). Newest top, hover xem full.
  // Race-safe append qua raw SQL: jsonb_array_append(system_messages, $event::jsonb).
  // KHÔNG dùng để filter chính (dùng dup_*_id index riêng) — chỉ for display.
  systemMessages Json @default("[]") @map("system_messages")

  // Normalized phone variants
  phoneE164     String? @map("phone_e164") // "+84908123456"
  phoneLocal    String? @map("phone_local") // "0908123456" — Vietnamese local format
  phoneValid    Boolean @default(false) @map("phone_valid")
  invalidReason String? @map("invalid_reason") // 'too_short' | 'invalid_format' | 'empty' | 'invalid_prefix'

  // Linkage to created Contact (if hợp lệ + not skipped)
  contactId String? @map("contact_id")

  // Zalo enrichment — populated by reverse-update from 3 event sources
  zaloUid          String?  @map("zalo_uid") // UID per nick
  zaloGlobalId     String?  @map("zalo_global_id") // cross-nick identity
  zaloName         String?  @map("zalo_name") // display name từ Zalo SDK
  resolvedByNickId String?  @map("resolved_by_nick_id") // ZaloAccount nào tìm ra UID này
  multiNickCount   Int      @default(0) @map("multi_nick_count") // số nick khác cùng tìm ra
  hasZalo          Boolean? @map("has_zalo") // null=chưa scan, true/false=đã scan

  // Dedup flags
  dupInListWithEntryId String? @map("dup_in_list_with_entry_id")
  dupWithListId        String? @map("dup_with_list_id")
  dupWithListEntryId   String? @map("dup_with_list_entry_id")
  dupWithContactId     String? @map("dup_with_contact_id")

  // State machine:
  //   pending → validated → [contact_created | dup_in_list | dup_cross_list |
  //   dup_with_crm | invalid] → enriched (has_zalo true/false)
  status       String    @default("pending")
  errorMessage String?   @map("error_message")
  enrichedAt   DateTime? @map("enriched_at")

  // Phase Multi-Source Lead Ads 2026-05-27 — schemaless lưu form fields biến động
  // (mỗi form FB/TikTok/Google có số câu hỏi khác nhau). customFields = answers từ
  // form lead-gen, sourceMeta = audit trail (campaignId, adId, formId, pageId,
  // leadId, deliveredAt, latencyMs...) để debug + analytics.
  customFields Json? @map("custom_fields")
  sourceMeta   Json? @map("source_meta")

  // #2 2026-06-06 (Anh chốt) — TOÀN BỘ cột hàng đợi + M9 override đã TÁCH sang bảng
  // nối TriggerQueueEntry (per-trigger, mỗi Mục tiêu độc lập). CustomerListEntry giờ
  // chỉ giữ data khách per-tệp (phone, zalo*, hasZalo, contactId, dup, status...).

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // #2 2026-06-06 — hàng đợi tách sang bảng nối per-trigger.
  queueRows TriggerQueueEntry[]

  // ── Facebook Lead Ads "Form" metadata 2026-06-09 (port từ main) ──────────
  // Cột riêng cho lead vào qua FB Lead Form (KHÁC luồng Campaign dùng sourceMeta JSON).
  fbLeadgenId     String?  @map("fb_leadgen_id")
  fbAdId          String?  @map("fb_ad_id")
  fbAdName        String?  @map("fb_ad_name")
  fbAdsetId       String?  @map("fb_adset_id")
  fbAdsetName     String?  @map("fb_adset_name")
  fbCampaignId    String?  @map("fb_campaign_id")
  fbCampaignName  String?  @map("fb_campaign_name")
  fbFormId        String?  @map("fb_form_id")
  fbFormName      String?  @map("fb_form_name")
  fbInboxUrl      String?  @map("fb_inbox_url")
  fbPlatform      String?  @map("fb_platform")
  fbIsOrganic     Boolean? @map("fb_is_organic")
  fbCustomAnswers Json?    @map("fb_custom_answers")

  @@unique([customerListId, rowIndex])
  @@index([customerListId, status])
  @@index([phoneE164]) // hot index for cross-list dedup + reverse update
  @@index([phoneLocal])
  @@index([customerListId, fbCampaignId])
  @@index([customerListId, fbFormId])
  @@map("customer_list_entries")
}

// #2 2026-06-06 (Anh chốt) — BẢNG NỐI hàng đợi per-Mục-tiêu.
// Mỗi Mục tiêu (trigger) độc lập hoàn toàn về khách, KHÔNG chống trùng: 1 khách
// (CustomerListEntry) có thể có N hàng — mỗi trigger 1 hàng, mỗi hàng 1 trạng thái
// xử lý riêng. Trước đây các cột này nằm thẳng trên CustomerListEntry nên 1 khách chỉ
// thuộc 1 trigger → 2 Mục tiêu chung tệp tranh nhau. Tách ra đây để chạy song song.
// Denormalize orgId/customerListId/contactId để claim/sweeper/sticky-hold query nhanh
// (sticky-hold + chat-handler filter theo contactId, không theo entryId).
model TriggerQueueEntry {
  id                  String  @id @default(uuid())
  triggerId           String  @map("trigger_id")
  customerListEntryId String  @map("customer_list_entry_id")
  // Denormalized scope keys (đọc/where nhanh không cần JOIN entry).
  orgId               String  @map("org_id")
  customerListId      String  @map("customer_list_id")
  contactId           String? @map("contact_id")

  // ── Hàng đợi (di dời từ CustomerListEntry) ──
  queueStatus        String    @default("queued_for_pickup") @map("queue_status")
  claimedByNickId    String?   @map("claimed_by_nick_id")
  lockedAt           DateTime? @map("locked_at")
  failedNickIds      Json      @default("[]") @map("failed_nick_ids") @db.JsonB
  stuckRecoveryCount Int       @default(0) @map("stuck_recovery_count")
  rateLimitCount     Int       @default(0) @map("rate_limit_count")
  nickHoldSince      DateTime? @map("nick_hold_since")
  restartCycle       Int       @default(0) @map("restart_cycle")
  lastResetReason    String?   @map("last_reset_reason")

  // ── M9 manual-enroll override (di dời — per-trigger, Anh chốt dời) ──
  sequenceIdOverride String?   @map("sequence_id_override")
  nickIdOverride     String?   @map("nick_id_override")
  enrolledBy         String?   @map("enrolled_by")
  enrollReason       String?   @map("enroll_reason")
  enrolledAt         DateTime? @map("enrolled_at")
  manualEnrollMeta   Json?     @map("manual_enroll_meta")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trigger AutomationTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  entry   CustomerListEntry @relation(fields: [customerListEntryId], references: [id], onDelete: Cascade)

  @@unique([triggerId, customerListEntryId]) // 1 cặp = 1 hàng đợi
  @@index([queueStatus, triggerId]) // dashboard groupBy + completion sweeper
  @@index([queueStatus, lockedAt]) // stuck sweeper
  @@index([claimedByNickId, queueStatus]) // sticky-hold disconnect/reconnect
  @@index([nickHoldSince]) // sticky-hold sweeper
  @@index([triggerId, contactId]) // chat-handler + accept/reject theo contact
  @@index([customerListEntryId]) // join entry→queue cho dashboard
  @@map("trigger_queue_entries")
}

// ════════════════════════════════════════════════════════════════════════
// CARESESSION (Phiên chăm sóc) — 2026-06-07
// Tách lớp LẮNG NGHE sự kiện khách + NHẮC sale khỏi trigger/sequence engine.
// Spec: ~/.gstack/projects/locphamnguyen-ZaloCRM/EVO-THANH-private-hs-design-engagement-session-20260607-023703.md
//
//   ┌─ TẠO ──────────────────────────────────────────────────────────────┐
//   │ Khách vào luồng (trigger auto HOẶC gắn tay) → INSERT CareSession    │
//   │ (Postgres = CHÂN LÝ, D2) → enqueue BullMQ sequence SAU → reconcile  │
//   └────────────────────────────────────────────────────────────────────┘
//   ┌─ NGHE (listener) ──────────────────────────────────────────────────┐
//   │ Tin/reaction/friend-event của KH → query phiên ĐANG MỞ              │
//   │ (orgId,contactId,nickId) JOIN trigger.state (D10).                  │
//   │ allowlist NGHE = [active, paused] (D12: paused VẪN nghe!).          │
//   │ nguồn ∈ [completed,cancelling,cancelled] → lazy-close + bỏ qua.     │
//   │ → reset interestWindowUntil + pause luồng + bắn notify.             │
//   └────────────────────────────────────────────────────────────────────┘
//   ┌─ ĐÓNG (BẤT KỲ cái nào tới trước) ──────────────────────────────────┐
//   │ • nguồn completed/cancelled (cascade hoặc lazy-close)               │
//   │ • đạt status/tag trong closeConditions (event-driven, đóng ngay)    │
//   │ • khách chặn                                                        │
//   │ • janitor: im lặng quá interestWindowUntil (set-based UPDATE, D5)   │
//   └────────────────────────────────────────────────────────────────────┘
// ════════════════════════════════════════════════════════════════════════

model CareSession {
  id    String @id @default(uuid())
  orgId String @map("org_id")

  // ── Khóa nhận diện (lookup phiên mở theo tuple này, có index) ──
  contactId        String  @map("contact_id")
  nickId           String  @map("nick_id")
  // Per-nick UID của khách (góc nhìn nick sale → nick khách) = Conversation.externalThreadId
  // = Friend.zaloUidInNick. Anh chốt 2026-06-08: phiên neo theo (nick, thread) để 1 nick có
  // 2 hội thoại cùng 1 Contact CHA vẫn tách phiên đúng. NULLABLE: phiên cũ + phiên no-Zalo
  // (virtual) để null → listener fallback "OR null" (khớp mọi thread) để không vỡ phiên cũ.
  externalThreadId String? @map("external_thread_id")

  // ── Sở hữu / nguồn ──
  ownerUserId      String  @map("owner_user_id") // sale phụ trách (chủ nick) — người HÀNH ĐỘNG
  enrolledByUserId String? @map("enrolled_by_user_id") // ai gắn tay (manager) — null nếu auto
  sourceType       String  @map("source_type") // 'trigger' | 'sequence_manual'
  sourceTriggerId  String? @map("source_trigger_id")
  sourceSequenceId String? @map("source_sequence_id")

  // ── Vòng đời ──
  state                   String    @default("active") // 'active' | 'closed'
  closedReason            String?   @map("closed_reason") // 'source_done'|'sale_resolved'|'customer_blocked'|'janitor_silence'|'deal_won'|'stranger_blocked'|'completed'
  // Snapshot điều kiện đóng từ trigger.closeConditions lúc tạo (mỗi phiên luật riêng).
  closeConditions         Json?     @map("close_conditions")
  // Cửa sổ im lặng: RESET mỗi event khách (D13 — reset mọi event, không chặn abuse).
  interestWindowUntil     DateTime  @map("interest_window_until")
  lastCustomerActivityAt  DateTime? @map("last_customer_activity_at")
  // CareSession 2026-06-07 (anh chốt): hiển thị pause cho sale ở trang Phiên chăm sóc.
  //   lastReplyAt  = KH trả lời lần cuối lúc nào (badge "💬 Vừa trả lời X phút trước").
  //   pausedUntil  = luồng bám đuổi tạm dừng tới khi nào (badge "⏸ chạy lại sau X giờ").
  //                  Đồng bộ với Redis pause flag (contact:paused TTL) — nguồn hiển thị.
  lastReplyAt             DateTime? @map("last_reply_at")
  pausedUntil             DateTime? @map("paused_until")
  // D2 reconcile marker: đã enqueue BullMQ start chưa (tránh enqueue trùng / mồ côi).
  sequenceStartEnqueuedAt DateTime? @map("sequence_start_enqueued_at")

  // ── Sequence recode Đợt 1 (2026-06-13) — luật 4 pause/resume, cột mềm nullable ──
  // pausedAtStepIdx: bước đang dở khi KH reply (pause). Resume worker đọc cột này để
  // re-enqueue ĐÚNG bước của ĐÚNG luồng (per-CareSession theo sourceSequenceId). NULL =
  // không đang pause-giữa-chừng. Clear sau khi resume re-enqueue xong.
  pausedAtStepIdx Int? @map("paused_at_step_idx")
  // pauseEpoch: tăng mỗi lần KH reply (pause). Resume chỉ re-enqueue nếu epoch khớp lúc
  // pause → chống "close cũ hồi sinh send sau reply mới" (Codex #2). NULL/0 = chưa pause.
  pauseEpoch      Int? @map("pause_epoch")
  // enrollEpoch (2026-06-15): SỐ LẦN gắn luồng này cho KH — gắn lại tăng epoch → jobId mới
  // (không đụng job cũ đã completed). Resume/cancel dùng đúng epoch của lần gắn này. NULL=1.
  enrollEpoch     Int? @map("enroll_epoch")
  // rulesSnapshot: chụp runtimeRules (giờ/sendGap/cooldown) lúc enroll → đổi cấu hình
  // KHÔNG ảnh hưởng KH đang chạy (Codex #10). NULL = dùng rules live của sequence (fallback).
  rulesSnapshot   Json? @map("rules_snapshot")

  openedAt DateTime  @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")

  org     Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trigger AutomationTrigger? @relation(fields: [sourceTriggerId], references: [id], onDelete: SetNull)
  events  CareSessionEvent[]

  // Lookup phiên mở cho listener (hot-path) — tuple + state.
  @@index([orgId, contactId, nickId, state])
  // Lookup theo (nick, thread) cho UI/SDK + per-conversation precision (2026-06-08).
  @@index([nickId, externalThreadId])
  // Janitor quét im-lặng đến hạn (D5: state + window).
  @@index([state, interestWindowUntil])
  // Cascade close + reconcile theo nguồn trigger.
  @@index([sourceTriggerId, state])
  // List "Phiên chăm sóc" theo sale (RBAC scope, D-frontend).
  @@index([orgId, ownerUserId, state])
  @@map("care_sessions")
}

// CareSessionEvent — append-only event log của phiên. Unique (sessionId, eventId)
// LÀ cơ chế idempotency chống double-process (D4): INSERT trùng → biết đã xử lý.
model CareSessionEvent {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  // eventId chuẩn hóa (D-notify): nickId:contactId:eventType:<providerMsgId|reactionId|timestampBucket>.
  // Phân tán (UUID-ish), KHÔNG sequential per-session → tránh hot unique-index (audit S2).
  eventId   String   @map("event_id")
  eventType String   @map("event_type") // 'reply'|'reaction_pos'|'reaction_neg'|'friend_accept'|'friend_reject'|'blocked'|'opened'|'paused'|'notified'|'closed'
  payload   Json? // nội dung tin / emoji (đưa vào notify)
  createdAt DateTime @default(now()) @map("created_at")

  session CareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, eventId]) // idempotency gate
  @@index([sessionId, createdAt]) // timeline per-phiên
  @@map("care_session_events")
}

// ════════════════════════════════════════════════════════════════════════
// RBAC PHASE PHÂN QUYỀN — 2026-05-21
// Department tree (org structure) + PermissionGroup tree (what actions)
// Reference: GetflyCRM model. Decisions locked ở
// ~/.gstack/projects/zalocrm/thanh-rbac-m2-design-20260521.md
// ════════════════════════════════════════════════════════════════════════

model Department {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  name         String
  parentId     String?   @map("parent_id")
  // Materialized path "/<rootId>/<midId>/<thisId>/" — query subtree bằng LIKE.
  // Auto recompute bởi trigger Postgres recompute_department_path() khi insert/update parent_id.
  path         String
  depth        Int       @default(0) // 0 = root, max 4 (5 level total per anh chốt)
  displayOrder Int       @default(0) @map("display_order")
  archivedAt   DateTime? @map("archived_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  org      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent   Department?        @relation("DeptTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Department[]       @relation("DeptTree")
  members  DepartmentMember[]

  @@index([orgId, path])
  @@index([parentId])
  @@map("departments")
}

model DepartmentMember {
  id           String   @id @default(uuid())
  departmentId String   @map("department_id")
  userId       String   @unique @map("user_id") // 1 user ∈ 1 dept (Q2 chốt)
  // dept_role: leader / deputy / member. Partial unique index ensure
  // tối đa 1 leader + 1 deputy mỗi dept (Q4 chốt).
  deptRole     String   @default("member") @map("dept_role")
  joinedAt     DateTime @default(now()) @map("joined_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([departmentId, deptRole])
  @@map("department_members")
}

model PermissionGroup {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  name         String
  parentId     String?   @map("parent_id") // tree UI grouping, mỗi node độc lập permission
  isSystem     Boolean   @default(false) @map("is_system") // Admin = protected, không xóa
  displayOrder Int       @default(0) @map("display_order")
  // FIX eng-review 2026-05-21: JSONB blob thay row-per-action (Issue 7).
  // Shape: { "<resource>": { "access": true, "create": false, "view_all": true, ... } }
  // 1 query lấy full matrix, parse in-memory, không N+1.
  grants       Json      @default("{}")
  archivedAt   DateTime? @map("archived_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  org      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent   PermissionGroup?  @relation("PermGroupTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children PermissionGroup[] @relation("PermGroupTree")
  users    User[]

  @@index([orgId])
  @@map("permission_groups")
}

// ════════════════════════════════════════════════════════════════════════
// PHASE RIÊNG TƯ — 2026-05-22
// PIN-gated visual privacy cho main nicks của user.
// Reference: ~/.gstack/projects/zalocrm/thanh-private-mode-design-20260521.md
// ════════════════════════════════════════════════════════════════════════

model UserPrivacySession {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  // Random 32-byte base64 token, set as HttpOnly cookie + sent qua axios interceptor (anh chốt Q3 Issue 3).
  sessionToken   String    @unique @map("session_token")
  unlockedAt     DateTime  @default(now()) @map("unlocked_at")
  expiresAt      DateTime  @map("expires_at")
  // Idle timeout 30 phút: client request đến → update lastActivityAt; nếu now() - lastActivityAt > 30m → server revoke.
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  ipHash         String?   @map("ip_hash") // audit cross-user (hash chống PII leak)
  // Phase Privacy v2 2026-05-23: raw IP để user thấy session DEVICE của chính mình (vd "192.168.1.200").
  // BE strict scope: chỉ user xem session ownership của mình → không cross-user leak.
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent") // audit + render "Cốc Cốc" / "Chrome" etc
  revokedAt      DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([userId, expiresAt])
  @@map("user_privacy_sessions")
}

// Phase Privacy OTP 2026-05-27 — thay PIN tự setup bằng OTP 4 số gửi Zalo nick nội bộ.
model PrivacyOtpToken {
  id                     String    @id @default(uuid())
  userId                 String    @map("user_id")
  otpHash                String    @map("otp_hash")
  sessionDurationMinutes Int       @map("session_duration_minutes")
  expiresAt              DateTime  @map("expires_at")
  verifyAttempts         Int       @default(0) @map("verify_attempts")
  lastSentAt             DateTime  @default(now()) @map("last_sent_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  usedAt                 DateTime? @map("used_at")
  ipAddress              String?   @map("ip_address")
  userAgent              String?   @map("user_agent")
  // 2026-06-06 — tách 2 luồng (anh chốt):
  //   'unlock'  = mở khoá XEM nội dung → verify tạo UserPrivacySession (có session, chọn duration).
  //   'enable'/'disable' = GẠT bật/tắt Riêng tư 1 nick → verify CHỈ xác nhận mã, KHÔNG tạo session.
  // nickId: bind OTP với đúng nick đang gạt (chống token-verify-nick-A-flip-nick-B). Null cho 'unlock'.
  action                 String    @default("unlock") @map("action")
  nickId                 String?   @map("nick_id")

  user User @relation("PrivacyOtpUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("privacy_otp_tokens")
}

// ════════════════════════════════════════════════════════════════════════
// Phase Lead Pool 2026-05-24 — Nhận Lead feature
// Sale rảnh → 1 click nhận lead bị bỏ rơi (forgotten Contact + CustomerList).
// Force note để xin lead tiếp. Spec đầy đủ: docs/DESIGN-LEAD-POOL.md
// ════════════════════════════════════════════════════════════════════════

model LeadRequest {
  id                 String    @id @default(uuid())
  orgId              String    @map("org_id")
  requestedByUserId  String    @map("requested_by_user_id")
  contactId          String    @map("contact_id")
  // 'forgotten' | 'customer_list' | 'external_sync'
  source             String
  priorityScore      Int       @map("priority_score")
  // Sale phải submit note ≥ noteMinLength để unlock xin lead tiếp.
  noteContent        String?   @map("note_content") @db.Text
  noteSubmittedAt    DateTime? @map("note_submitted_at")
  // Auto-return về pool nếu quá hạn không note
  expiresAt          DateTime  @map("expires_at")
  autoReturnedAt     DateTime? @map("auto_returned_at")
  // 'completed' | 'auto_return' | 'manual_return' | null (still active)
  releaseReason      String?   @map("release_reason")
  // Rollback target khi trả pool
  previousAssigneeId String?   @map("previous_assignee_id")
  requestedAt        DateTime  @default(now()) @map("requested_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [requestedByUserId], references: [id])
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([orgId, requestedByUserId, requestedAt(sort: Desc)])
  @@index([contactId, requestedAt(sort: Desc)])
  @@index([requestedByUserId, noteSubmittedAt])
  @@index([expiresAt, autoReturnedAt])
  @@map("lead_requests")
}

model LeadPoolConfig {
  id                     String  @id @default(uuid())
  orgId                  String  @unique @map("org_id")
  enabled                Boolean @default(true)
  maxRequestsPerDay      Int     @default(10) @map("max_requests_per_day")
  cooldownMinutes        Int     @default(15) @map("cooldown_minutes")
  forgottenThresholdDays Int     @default(30) @map("forgotten_threshold_days")
  // JSON array of status keys to EXCLUDE from pool (sale đang chăm tốt)
  excludedStatuses       Json    @default("[\"hot\",\"potential\",\"won\"]") @map("excluded_statuses")
  // Deprecated 2026-05-27 — kept để backward-compat read. Code mới dùng autoReturnAfterMinutes.
  autoReturnAfterDays    Int     @default(7) @map("auto_return_after_days")
  // Phase Lead Pool v2 2026-05-27 — anh chốt granular phút, range 30 phút → 7 ngày (10080 phút).
  // Default 1440 phút = 1 ngày. Lead bị hold lâu quá thì sale khác chờ → giảm xuống cho rotate nhanh.
  autoReturnAfterMinutes Int     @default(1440) @map("auto_return_after_minutes")
  // Phase v2 — lead chỉ có UID (no phone) không nên vào pool vì sale mới không liên lạc được
  // (UID per-viewer của sale cũ, không dùng được với nick mới). Default true = bắt buộc phone.
  // Admin tắt nếu muốn force redistribute UID-only lead (sale tự gọi findUser qua nick mình).
  requirePhoneInPool     Boolean @default(true) @map("require_phone_in_pool")
  forceNoteBeforeNext    Boolean @default(true) @map("force_note_before_next")
  // JSON array: 'forgotten' | 'customer_list' | 'external_sync'
  enabledSources         Json    @default("[\"forgotten\",\"customer_list\"]") @map("enabled_sources")
  noteMinLength          Int     @default(20) @map("note_min_length")
  // 2026-05-29 Phase v2.B — Cooldown sau note. Sale note xong → KH này KHÔNG vào pool
  // ai khác trong N ngày. Sale gốc vẫn chăm KH bình thường. Sale bấm "Trả lại pool" →
  // bypass cooldown. Default 30 ngày.
  cooldownAfterNoteDays  Int     @default(30) @map("cooldown_after_note_days")
  // 2026-05-29 Phase v2.I — Self-reclaim lock. Sale trả lead → sale đó KHÔNG được nhận
  // lại chính KH đó trong N ngày. Sale khác vẫn xin được ngay. Chống spam loop khi
  // sale gốc tự xin-trả-xin lại cùng 1 KH. Default 7 ngày.
  selfReclaimLockDays    Int     @default(7) @map("self_reclaim_lock_days")
  // 2026-05-28 — JSON array string templates câu chào mặc định khi mở lead modal.
  // Placeholders hỗ trợ:
  //   {anh_chi}   — "Anh" | "Chị" | "Anh/Chị" (capitalize, dùng đầu câu)
  //   {ac}        — "anh" | "chị" | "anh/chị" (lowercase, dùng giữa câu)
  //   {ten_kh}    — tên riêng KH (từ cuối fullName, ví dụ "Tran" cho "Tram Tran")
  //   {ten_em}    — tên riêng sale (từ cuối fullName)
  // Empty array → service fallback default 3 câu hardcode. Admin PATCH config để thêm/sửa.
  greetingTemplates      Json    @default("[]") @map("greeting_templates")
  // 2026-06-19 (D) — Pool chỉ lấy lead từ các tệp KH (CustomerList) này. Rỗng = mọi tệp
  // shareable_to_pool=true (hành vi cũ). Chỉ áp khi nguồn 'customer_list' đang bật.
  sourceListIds          Json    @default("[]") @map("source_list_ids")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("lead_pool_configs")
}

// Phase Lead Pool 2026-05-28 — Admin/Manager cấp thêm quota cho sale sau khi review
// hết noted leads hôm nay. checkEligibility SUM(bonusCount) WHERE dateKey=today (VN tz).
model LeadPoolBonusQuota {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  userId          String   @map("user_id")
  dateKey         String   @map("date_key")
  bonusCount      Int      @map("bonus_count")
  grantedByUserId String   @map("granted_by_user_id")
  reviewedLeadIds Json     @default("[]") @map("reviewed_lead_ids")
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation("LeadPoolBonusRecipient", fields: [userId], references: [id])
  grantedBy User         @relation("LeadPoolBonusGranter", fields: [grantedByUserId], references: [id])

  @@index([orgId, userId, dateKey])
  @@index([orgId, dateKey])
  @@map("lead_pool_bonus_quotas")
}

// Phase Lead Pool FIFO 2026-06-15 — sổ phát lead. Mỗi lần chia 1 dòng.
// Dùng cho view "Nhật ký chia" + đếm số lần. KHÔNG thay LeadRequest (lo note/return).
// Nguồn sự thật cho "đã chia mấy lần" = Contact.pooledCount / cột round, KHÔNG đếm
// COUNT(*) bảng này (chỉ ghi từ lúc deploy, lead cũ thiếu).
model LeadPoolDistribution {
  id               String   @id @default(uuid())
  orgId            String   @map("org_id")
  // SetNull (KHÔNG cascade) — giữ audit kể cả khi Contact bị xoá/merge; phoneNormalized snapshot.
  contactId        String?  @map("contact_id")
  phoneNormalized  String?  @map("phone_normalized")
  assignedToUserId String   @map("assigned_to_user_id")
  source           String // 'forgotten' | 'customer_list' | 'external_sync'
  // Lần thứ mấy lead này được chia (snapshot pooledCount SAU increment). round=1 là lần đầu.
  round            Int
  leadRequestId    String?  @map("lead_request_id")
  distributedAt    DateTime @default(now()) @map("distributed_at")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact    Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo User         @relation("LeadDistributionRecipient", fields: [assignedToUserId], references: [id])

  @@index([orgId, distributedAt(sort: Desc)])
  @@index([orgId, assignedToUserId, distributedAt(sort: Desc)])
  @@index([contactId, distributedAt(sort: Desc)])
  @@map("lead_pool_distributions")
}

// =============================================================================
// Phase Multi-Source Lead Ads 2026-05-27
// Adapter Pattern — ingest leads từ FB / TikTok / Google / Zalo Ads vào
// CustomerList theo #KEY trong campaign name.
// Design doc: ~/.gstack/projects/zalocrm/EVO-THANH-private-hs-design-fb-leadads-routing-20260524-213635.md
// =============================================================================

// Page Facebook đã connect → orgId mapping (multi-tenant isolation).
// Token AES-256-GCM ciphertext, decrypt only at fetch time. webhookVerifyToken
// dùng cho hub.challenge handshake với Meta. App-secret level shared cross-pages.
model FacebookPageAccount {
  id                   String    @id @default(uuid())
  orgId                String    @map("org_id")
  pageId               String    @unique @map("page_id") // FB page ID
  pageName             String?   @map("page_name")
  encryptedAccessToken String    @map("encrypted_access_token") @db.Text // AES-256-GCM blob
  webhookVerifyToken   String    @map("webhook_verify_token") // hub.challenge
  isActive             Boolean   @default(true) @map("is_active")
  connectedByUserId    String?   @map("connected_by_user_id")
  subscribedAt         DateTime  @default(now()) @map("subscribed_at")
  lastWebhookAt        DateTime? @map("last_webhook_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isActive])
  @@map("facebook_page_accounts")
}

// Phase FB Pull 2026-05-30 — registry mỗi leadgen_form của Page + checkpoint cho
// incremental pull. Watermark lastPulledLeadCreatedTime là checkpoint chính (bền vững
// hơn Graph cursor giữa các tick). Cursor chỉ phân trang trong cùng 1 lần pull.
model FacebookLeadgenForm {
  id       String  @id @default(uuid())
  orgId    String  @map("org_id")
  pageId   String  @map("page_id") // FK logic tới FacebookPageAccount.pageId
  formId   String  @map("form_id") // FB leadgen form ID
  formName String? @map("form_name")
  status   String  @default("active") // 'active' | 'archived' | 'deleted'

  // Checkpoint incremental pull
  lastPulledLeadCreatedTime DateTime? @map("last_pulled_lead_created_time") // watermark (UTC)
  lastPulledCursor          String?   @map("last_pulled_cursor") @db.Text // Graph "after" cursor
  lastPullAt                DateTime? @map("last_pull_at")
  lastPullLeadCount         Int       @default(0) @map("last_pull_lead_count")
  lastPullError             String?   @map("last_pull_error") @db.Text
  consecutiveErrors         Int       @default(0) @map("consecutive_errors")
  // historyBackfilled=false → lần pull tiếp theo kéo TOÀN BỘ lead lịch sử (anh chốt kéo lead cũ).
  // Sau khi backfill xong → true, các tick sau chỉ kéo lead mới qua watermark.
  historyBackfilled         Boolean   @default(false) @map("history_backfilled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([pageId, formId])
  @@index([orgId, status])
  @@index([status, lastPullAt])
  @@map("facebook_leadgen_forms")
}

// Outbox + audit cho mọi webhook delivery từ ad-network. Idempotent qua
// externalLeadId unique. processingSteps = timing trace cho Phase 2 timeline UI.
// orgId nullable cho early-error stage (page chưa connect). createdEntryId fill
// sau khi worker insert CustomerListEntry thành công.
model WebhookLog {
  id              String    @id @default(uuid())
  orgId           String?   @map("org_id")
  source          String // 'fb-leadads' | 'tiktok-leadgen' | 'google-leadform' | 'zalo-ads'
  externalLeadId  String    @unique @map("external_lead_id")
  rawBody         Json      @map("raw_body")
  signature       String? // X-Hub-Signature-256 (audit)
  status          String    @default("pending") // 'pending' | 'processing' | 'processed' | 'failed'
  attempts        Int       @default(0)
  nextRetryAt     DateTime? @map("next_retry_at")
  errorMessage    String?   @map("error_message") @db.Text
  createdEntryId  String?   @map("created_entry_id") // CustomerListEntry.id sau khi route
  processingSteps Json?     @map("processing_steps") // {parseMs, graphApiMs, ...} Phase 2 timeline
  createdAt       DateTime  @default(now()) @map("created_at")
  processedAt     DateTime? @map("processed_at")

  @@index([source, status, nextRetryAt])
  @@index([orgId, source, createdAt])
  @@map("webhook_logs")
}

// 5-min TTL cache map campaignId → matched #KEY + listId. Stale detection qua
// campaignName comparison khi webhook tới (caller re-fetch nếu name đổi).
// Invalidate khi admin đổi integrationKey trên list (cachedAt set epoch).
model MetaCampaignCache {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  campaignId    String   @unique @map("campaign_id")
  campaignName  String   @map("campaign_name")
  matchedKey    String?  @map("matched_key") // #KEY parsed từ campaignName
  matchedListId String?  @map("matched_list_id") // null = Unrouted indicator
  cachedAt      DateTime @default(now()) @map("cached_at")

  @@index([matchedListId])
  @@map("meta_campaign_cache")
}

// Dedup notify storm — 1 notify per (orgId, notifyKey) trong 24h window.
// counter ++ mỗi event thêm để show "5 lead mới chưa route" thay vì spam.
// Atomic upsert qua unique(orgId, notifyKey). GC worker xoá row expired.
model NotifyDedupState {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  notifyKey   String   @map("notify_key") // e.g. "unrouted:campaign:12345"
  counter     Int      @default(1)
  firstSentAt DateTime @default(now()) @map("first_sent_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  expiresAt   DateTime @map("expires_at")

  @@unique([orgId, notifyKey])
  @@index([expiresAt])
  @@map("notify_dedup_state")
}

// =============================================================================
// Phase Friend Invite Queue 2026-05-28 — Outbox cho atomic send + sequence materialize
// =============================================================================
//
// Worker dispatch flow 3-phase:
//   Phase 1 CLAIM: UPDATE entry status=processing (short DB tx)
//   Phase 2 HTTP:  Zalo SDK call (NO DB tx, 30s timeout)
//   Phase 3 RESULT (short DB tx):
//     - Success → UPDATE entry status=processed + INSERT outbox sendStatus=success
//     - Fail → UPDATE entry status=queued_for_pickup, append failedNickIds
//     - Timeout → UPDATE entry status=processed + INSERT outbox sendStatus=tentative
//
// Outbox drainer cron 30s: pick outbox WHERE sendStatus=success AND sequenceMaterializedAt IS NULL
// → call materializeSequenceForContact() → UPDATE sequenceMaterializedAt
//
// Crash recovery: nếu worker crash giữa Phase 2 và Phase 3 → entry stuck processing
// → stuck sweeper after 5 phút release back to pool (documented duplicate-send risk).
model FriendRequestOutbox {
  id                      String    @id @default(uuid())
  customerListEntryId     String    @map("customer_list_entry_id")
  triggerId               String    @map("trigger_id")
  nickId                  String    @map("nick_id")
  contactId               String    @map("contact_id")
  successorSequenceId     String?   @map("successor_sequence_id")
  // Snapshot Sequence steps tại insert time → edit Sequence mid-run KHÔNG affect
  sequenceVersionSnapshot Json?     @map("sequence_version_snapshot")
  sendStatus              String    @map("send_status") // success | tentative | failed
  zaloLeadgenId           String?   @map("zalo_leadgen_id")
  sequenceMaterializedAt  DateTime? @map("sequence_materialized_at")
  attemptCount            Int       @default(0) @map("attempt_count")
  lastErrorMessage        String?   @map("last_error_message") @db.Text
  createdAt               DateTime  @default(now()) @map("created_at")

  // Wave 2 Welcome Probe 2026-05-29 — outbox cũng dùng cho welcome task sau friend accept
  kind                 String    @default("FRIEND_REQUEST") @map("kind") // FRIEND_REQUEST | WELCOME
  parentTaskId         String?   @map("parent_task_id") // link welcome → friend_request gốc
  allowStrangerMessage Boolean   @default(false) @map("allow_stranger_message")
  welcomeOutcome       String?   @map("welcome_outcome") // sent | retry | dropped | blocked | awaiting_nick
  welcomeSentAt        DateTime? @map("welcome_sent_at")
  welcomeRetryCount    Int       @default(0) @map("welcome_retry_count")
  welcomeLastError     String?   @map("welcome_last_error") @db.Text

  // ── Sticky Nick 24h Hold (Sprint v3 2026-06-03) ──
  // attemptRound = vòng welcome thứ N cho cùng (contact, trigger). Tăng khi
  // sweeper reset KH (đồng bộ với entry.restartCycle). Cho phép gửi welcome
  // lại sau reset mà không vi phạm unique index.
  // nickFirstOfflineAt = mốc nick gốc disconnect lần đầu khi welcome-probe
  // gặp nick offline → set 1 lần, dùng để compute thời gian chờ nick hồi.
  attemptRound       Int       @default(0) @map("attempt_round")
  nickFirstOfflineAt DateTime? @map("nick_first_offline_at")

  // Legacy unique constraint từ Wave 2 Welcome Probe (di sản DB).
  // Declare lại trong schema để Prisma db push không cố drop khi restart container.
  @@unique([customerListEntryId, kind], map: "friend_request_outbox_customer_list_entry_id_kind_key")
  @@index([sendStatus, sequenceMaterializedAt])
  @@index([nickId, createdAt]) // hot index for todayCount recovery on worker restart
  @@index([kind, sendStatus], map: "idx_outbox_kind_send_status_run_at")
  @@index([welcomeOutcome], map: "idx_outbox_welcome_outcome")
  // Welcome per-(contact, trigger) 2026-06-02 — DB-enforced dedup guard.
  // Partial unique index defined in 20260602170000_welcome_per_trigger migration.sql
  // (Prisma cannot express PARTIAL UNIQUE WHERE in schema; declared manually via SQL).
  // Helper read index idx_outbox_welcome_dedup also declared in same migration.
  @@map("friend_request_outbox")
}

// (Wave 3 Event Log model định nghĩa trước đã merge với Luồng Mục Tiêu M3 model ở dòng 2186)

// ════════════════════════════════════════════════════════════════════════
// Facebook Lead Ads — "Form" ingestion (port từ main 2026-06-09)
// ════════════════════════════════════════════════════════════════════════
// Bổ trợ cho luồng "Campaign" (#KEY) đã có. Form: OAuth Page → webhook leadgen
// → map form→CustomerList → round-robin chia sale. Sống song song, prefix route
// chung /api/v1/integrations/facebook nhưng sub-path khác (/oauth /pages /mappings).
model FacebookPageConnection {
  id             String    @id @default(cuid())
  orgId          String    @map("org_id")
  pageId         String    @map("page_id")
  pageName       String    @map("page_name")
  accessTokenEnc String    @map("access_token_enc") // AES-256-GCM
  tokenExpiresAt DateTime? @map("token_expires_at")
  subscribedAt   DateTime? @map("subscribed_at")
  status         String    @default("connected") // connected | revoked | error
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  mappings     FacebookFormMapping[]

  @@unique([orgId, pageId])
  @@map("facebook_page_connections")
}

model FacebookFormMapping {
  id               String   @id @default(cuid())
  orgId            String   @map("org_id")
  pageConnectionId String   @map("page_connection_id")
  formId           String   @map("form_id")
  formName         String   @map("form_name")
  customerListId   String   @map("customer_list_id")
  fieldMap         Json     @default("{}") @map("field_map")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")

  organization   Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pageConnection FacebookPageConnection @relation(fields: [pageConnectionId], references: [id], onDelete: Cascade)
  customerList   CustomerList           @relation(fields: [customerListId], references: [id], onDelete: Cascade)

  @@unique([orgId, formId])
  @@map("facebook_form_mappings")
}

model FacebookLeadEvent {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  leadgenId   String    @unique @map("leadgen_id") // FB lead ID — idempotency
  formId      String    @map("form_id")
  pageId      String    @map("page_id")
  rawPayload  Json      @map("raw_payload")
  processedAt DateTime? @map("processed_at")
  contactId   String?   @map("contact_id")
  listEntryId String?   @map("list_entry_id")
  error       String?
  retryCount  Int       @default(0) @map("retry_count")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([orgId, formId])
  @@index([createdAt])
  @@map("facebook_lead_events")
}

model CustomerListSaleAssignment {
  id             String   @id @default(cuid())
  customerListId String   @map("customer_list_id")
  userId         String   @map("user_id")
  weight         Int      @default(1)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  customerList CustomerList @relation(fields: [customerListId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([customerListId, userId])
  @@map("customer_list_sale_assignments")
}

model SaleAssignmentState {
  id                 String   @id @default(cuid())
  orgId              String   @map("org_id")
  customerListId     String   @unique @map("customer_list_id")
  lastAssignedUserId String?  @map("last_assigned_user_id")
  counter            Int      @default(0)
  updatedAt          DateTime @updatedAt @map("updated_at")

  customerList CustomerList @relation(fields: [customerListId], references: [id], onDelete: Cascade)

  @@map("sale_assignment_states")
}

// ════════════════════════════════════════════════════════════════════════
// Facebook App config per-org (Phase FB 2-tab 2026-06-10)
// ════════════════════════════════════════════════════════════════════════
// Điền qua UI (nút ⚙ Cấu hình ở cả 2 tab). Code đọc DB per-org → fallback env.
// appSecret + tokenEncKey mã hoá AT-REST bằng env TOKEN_ENCRYPTION_KEY (token-encryption.util).
model FacebookAppConfig {
  id                 String   @id @default(cuid())
  orgId              String   @unique @map("org_id")
  appId              String?  @map("app_id")
  appSecretEnc       String?  @map("app_secret_enc") @db.Text // encryptToken(appSecret)
  webhookVerifyToken String?  @map("webhook_verify_token")
  tokenEncKeyEnc     String?  @map("token_enc_key_enc") @db.Text // encryptToken(FB_TOKEN_ENC_KEY)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("facebook_app_configs")
}

// ════════════════════════════════════════════════════════════════════════════
// Phase Media Library 2026-06-11 (Anh chốt qua office-hours + CEO/Eng/Design review)
// Mô hình 2 tầng (eng review E2/E3):
//   • MediaBlob  = OBJECT THÔ trên MinIO, dedup theo sha256 BYTES THẬT LƯU.
//                  1 Asset có nhiều Blob variant (original / watermarked / compressed).
//   • MediaAsset = DANH TÍNH + metadata + quyền (KHÔNG mang minioKey trực tiếp).
//   Dedup ở tầng Blob (hash), query kho ở tầng Asset.
// INVARIANT: object immutable, "xóa" = archive (archivedAt), không 404 lịch sử chat.
// (MediaUploadRef cache forward-ref ĐÃ BỎ 2026-06-12: zca-js không forward được media
//  → luôn gửi lẻ Đường B, ref không bao giờ dùng. Xem reference_zalo_forward_media_impossible.)
// ════════════════════════════════════════════════════════════════════════════

// MediaBlob — object thô trên MinIO. Dedup theo contentHash (sha256 bytes đã lưu).
// 1 asset → nhiều blob variant. Gửi N lần cùng 1 variant = 1 object duy nhất.
model MediaBlob {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  assetId     String   @map("asset_id")
  // sha256 của BYTES THẬT LƯU lên MinIO (đã nén nếu là variant compressed/original-nén).
  contentHash String   @map("content_hash")
  variantType String   @default("original") @map("variant_type") // 'original' | 'watermarked' | 'compressed'
  minioKey    String   @map("minio_key") // key trên MinIO: media/{contentHash}{ext}
  publicUrl   String   @map("public_url")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  width       Int?
  height      Int?
  durationSec Int?     @map("duration_sec") // video
  createdAt   DateTime @default(now()) @map("created_at")

  org        Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset      MediaAsset       @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Dedup key: cùng org + cùng bytes = 1 blob. statObject + upsert chống trùng.
  @@unique([orgId, contentHash])
  @@index([assetId])
  @@map("media_blobs")
}

// MediaAsset — danh tính 1 "tấm ảnh/file" trong kho (vd "Bảng giá EGV").
// Pattern copy từ MessageTemplate (org/owner/visibility/createdBy/tagIds/usageCount).
model MediaAsset {
  id                  String    @id @default(uuid())
  orgId               String    @map("org_id")
  kind                String // 'image' | 'video' | 'file'
  name                String
  // ownerUserId: chủ sở hữu (sale lưu/tải lên). NULL = tài sản chung org.
  ownerUserId         String?   @map("owner_user_id")
  // visibility: 'private' (chỉ owner) | 'public' (cả org). Mặc định private — fail-closed.
  visibility          String    @default("private")
  // source: phân biệt nguồn nạp để audit privacy. 'upload' = sale/admin tải lên;
  // 'saved_from_chat' = lưu từ bong bóng chat (có thể chứa PII khách).
  source              String    @default("upload")
  // Nick Zalo NGUỒN của ảnh lưu từ chat — để HIỂN THỊ "ảnh từ nick nào" (mọi nick, cả
  // nick thường lẫn Riêng tư). 2026-06-15: trước đây CHỈ ghi khi nick Riêng tư; nay ghi
  // cho MỌI ảnh lưu từ chat. Ảnh upload tay = null (nguồn = "Tải lên thủ công" + sale).
  sourceZaloAccountId String?   @map("source_zalo_account_id")
  // 2026-06-15: TÁCH cờ ENFORCE privacy khỏi nick-nguồn-hiển-thị. true CHỈ khi ảnh lưu từ
  // nick Riêng tư (privacyMode='main') → gate confirmShare khi public + cảnh báo D11. Trước
  // đây code suy cờ từ `!!sourceZaloAccountId`; nick thường giờ cũng có id nên PHẢI đọc cờ này.
  sourceIsPrivateNick Boolean   @default(false) @map("source_is_private_nick")
  folderId            String?   @map("folder_id") // MediaAlbum dùng làm "thư mục" (parentId=null)
  tagIds              String[]  @default([]) @map("tag_ids") // tag dự án (EGV/HS...) — Gin index
  originalFilename    String?   @map("original_filename")
  thumbnailUrl        String?   @map("thumbnail_url") // video thumbnail
  // Watermark per-ảnh (GĐ2): BẬT/TẮT + góc + độ mờ. Khi BẬT, gửi đi dùng blob 'watermarked'.
  watermarkEnabled    Boolean   @default(false) @map("watermark_enabled")
  watermarkPosition   String    @default("bottom-right") @map("watermark_position") // bottom-right|bottom-left|top-right|top-left|center
  watermarkOpacity    Float     @default(0.65) @map("watermark_opacity")
  usageCount          Int       @default(0) @map("usage_count")
  lastUsedAt          DateTime? @map("last_used_at")
  archivedAt          DateTime? @map("archived_at") // soft delete = DẤU THÙNG RÁC — KHÔNG xóa object MinIO
  // GĐ13a (2026-06-12): ai bỏ asset vào thùng rác (audit + scope sale). NULL = chưa từng/đã khôi phục.
  trashedById         String?   @map("trashed_by_id")
  createdById         String?   @map("created_by_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  org        Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner      User?            @relation("MediaAssetOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy  User?            @relation("MediaAssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  folder     MediaAlbum?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // 2026-06-15: relation tới nick nguồn để Prisma `include` join displayName 1 query (chống
  // N+1 khi list 60-200 ảnh hiện "nick nào"). SetNull: nick xóa → vẫn giữ ảnh, mất tên nick.
  sourceZaloAccount ZaloAccount? @relation("MediaAssetSourceNick", fields: [sourceZaloAccountId], references: [id], onDelete: SetNull)
  blobs      MediaBlob[]
  albumItems MediaAlbumItem[]
  usageEvents MediaUsageEvent[]

  @@index([orgId, kind])
  @@index([orgId, visibility])
  @@index([orgId, ownerUserId])
  @@index([orgId, archivedAt])
  @@index([folderId])
  @@index([sourceZaloAccountId])
  @@index([tagIds], type: Gin)
  @@map("media_assets")
}

// MediaAlbum — thư mục/bộ sưu tập (gồm cả "Yêu thích" cá nhân tự động).
// Pattern copy y MessageTemplateFolder. visibility='public' → cả org; 'private' → owner.
model MediaAlbum {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  // kind: 'folder' (thư mục thường) | 'favorite' (bộ sưu tập Yêu thích cá nhân tự động).
  kind        String   @default("folder")
  visibility  String   @default("private")
  ownerUserId String?  @map("owner_user_id")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner     User?            @relation("MediaAlbumOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy User             @relation("MediaAlbumCreatedBy", fields: [createdById], references: [id])
  items     MediaAlbumItem[]
  assets    MediaAsset[] // assets dùng album này làm folder

  @@index([orgId, visibility])
  @@index([orgId, ownerUserId])
  @@index([orgId, kind])
  @@map("media_albums")
}

// MediaAlbumItem — 1 asset trong 1 album (bảng nối N-N + thứ tự).
model MediaAlbumItem {
  id           String   @id @default(uuid())
  albumId      String   @map("album_id")
  mediaAssetId String   @map("media_asset_id")
  position     Int      @default(0)
  caption      String?
  createdAt    DateTime @default(now()) @map("created_at")

  album MediaAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  asset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([albumId, mediaAssetId])
  @@index([mediaAssetId])
  @@map("media_album_items")
}

// MediaUsageEvent — log từng lần media được gửi (tách event type để sau aggregate).
// Codex/observability S8 + usageCount-tách-event: usageCount giữ tổng (đếm nhanh),
// event này lưu chi tiết loại (sent_chat / sent_album / broadcast / saved_public).
model MediaUsageEvent {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  mediaAssetId String   @map("media_asset_id")
  // eventType: 'sent_chat' | 'sent_album' | 'broadcast' | 'saved_from_chat' | 'made_public'
  eventType    String   @map("event_type")
  userId       String?  @map("user_id") // ai thực hiện (audit privacy)
  conversationId String? @map("conversation_id")
  meta         Json?    // dữ liệu phụ (vd albumCount, deduped, fromPrivateNick)
  createdAt    DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset MediaAsset   @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([orgId, eventType])
  @@index([mediaAssetId])
  @@index([orgId, createdAt])
  @@map("media_usage_events")
}
