generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Top-level org — every resource is scoped to an org
model Organization {
  id       String @id @default(uuid())
  name     String
  // Múi giờ mặc định của tổ chức (offset cố định, không tự DST). Format "+07:00" / "-05:00".
  // Mặc định +07:00 (Việt Nam) để mọi timestamp render trong UI và log đều đồng nhất, dễ decode.
  timezone String @default("+07:00")

  // ── Login branding 2026-06-12 — hiển thị ngoài trang /login (PRE-AUTH) ──────
  // Trang đăng nhập đọc 4 trường này qua endpoint công khai /api/v1/public/org-branding
  // thay vì hardcode. logoUrl trỏ ảnh trong kho media (publicUrl) hoặc asset tĩnh
  // /brand/*. emailDomain dùng gợi ý placeholder "user@<emailDomain>" (vd tenmien.com),
  // KHÔNG suy ra từ window.location (tránh ra user@localhost khi cài localhost).
  logoUrl     String? @map("logo_url")
  slogan      String?
  copyright   String?
  emailDomain String? @map("email_domain")

  // Phase FB Pull 2026-05-30 — System User token (vĩnh viễn, quyền leads_retrieval) để
  // KÉO lead chủ động từ form quảng cáo (chính chủ, không cần App Review). 1 SU token đọc
  // được mọi Page mà System User được gán → lưu cấp Org. AES-256-GCM blob, decrypt tại fetch.
  encryptedFbSystemUserToken String? @map("encrypted_fb_system_user_token") @db.Text
  fbPullEnabled              Boolean @default(false) @map("fb_pull_enabled")
  fbSystemUserId             String? @map("fb_system_user_id") // audit: SU id, debug khi revoke

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teams                       Team[]
  users                       User[]
  zaloAccounts                ZaloAccount[]
  contacts                    Contact[]
  contactAccess               ContactAccess[]
  conversations               Conversation[]
  appointments                Appointment[]
  activityLogs                ActivityLog[]
  dailyStats                  DailyMessageStat[]
  settings                    AppSetting[]
  duplicateGroups             DuplicateGroup[]
  savedReports                SavedReport[]
  integrations                Integration[]
  facebookLeadgenForms        FacebookLeadgenForm[]
  automationRules             AutomationRule[]
  messageTemplates            MessageTemplate[]
  aiConfig                    AiConfig?
  aiSuggestions               AiSuggestion[]
  aiSuggestionsApplied        AiSuggestionApplied[]
  pinnedConversations         PinnedConversation[]
  groupPolls                  GroupPoll[]
  friendshipAttempts          FriendshipAttempt[]
  friends                     Friend[]
  statuses                    Status[]
  parentCandidates            ParentCandidate[]
  notes                       Note[]
  zaloLabels                  ZaloLabel[]
  crmTags                     CrmTag[]
  crmTagGroups                CrmTagGroup[]
  // Phase 6 — Lead Scoring Engine relations
  scoringConfig               ScoringConfig?
  scoreSignalRules            ScoreSignalRule[]
  stageTransitionRules        StageTransitionRule[]
  stuckThresholds             StuckThreshold[]
  nbaTemplates                NbaTemplate[]
  // Phase 6+ — Inbox Triage Filter relations
  accountFolders              AccountFolder[]
  savedFilterPresets          SavedFilterPreset[]
  // Phase 7 — Automation framework (Block / Sequence / Trigger / Broadcast / Campaign / Task)
  blocks                      Block[]
  blockFolders                BlockFolder[]
  messageTemplateFolders      MessageTemplateFolder[]
  automationSequences         AutomationSequence[]
  automationTriggers          AutomationTrigger[]
  automationBroadcasts        AutomationBroadcast[]
  automationCampaigns         AutomationCampaign[]
  // automationTasks       AutomationTask[]  ← REMOVED 2026-06-01 Luồng Mục Tiêu M0
  automationEventLogs         AutomationEventLog[]
  // CareSession (Phiên chăm sóc) 2026-06-07
  careSessions                CareSession[]
  // RBAC Phase Phân Quyền 2026-05-21
  departments                 Department[]
  permissionGroups            PermissionGroup[]
  // Phase ZaloAccounts redesign 2026-05-22 — status log uptime
  zaloAccountStatusLog        ZaloAccountStatusLog[]
  // Phase metrics layer 2026-05-22 — phone search log
  phoneSearchEvents           PhoneSearchEvent[]
  // Phase Privacy v2 2026-05-23 — nick chuyên dùng GỬI system notification cho cả org.
  // Admin pick bất kỳ nick connected. FK SET NULL khi nick bị xóa.
  systemNotifyZaloAccountId   String?                 @map("system_notify_zalo_account_id")
  systemNotifyNick            ZaloAccount?            @relation("OrgSystemNotify", fields: [systemNotifyZaloAccountId], references: [id], onDelete: SetNull)
  systemNotifyRecipients      SystemNotifyRecipient[]
  systemNotifications         SystemNotification[]
  // CareSession 2026-06-07 — UID nhóm Zalo nhận thông báo "đích nhóm" (nhìn từ góc
  // nick hệ thống gửi, giống per-nick UID 1-1). Admin nhập tay ở Settings. Gửi qua
  // sendMessage(threadId, threadType=1). null = đích nhóm tắt.
  internalNotifyGroupThreadId String?                 @map("internal_notify_group_thread_id")
  // CareSession 2026-06-07 (anh chốt): "Lắng nghe & Nhắc chăm sóc" là cấu hình CHUNG
  // toàn tổ chức (KHÔNG per-trigger). 1 bộ quy tắc cho mọi Mục tiêu.
  //   careNotifyChannels: { "<eventKey>": { owner, manager, zaloGroup } }
  //     eventKey care event: reply|reactionPositive|reactionNegative|lead|block|friendAccept|friendReject
  //   careCloseConditions: { onStatusIds, onFriendTagIds, onCrmTagIds, silenceDays }
  // (Field cùng tên trên AutomationTrigger giữ lại làm legacy, backend đọc ORG trước.)
  careNotifyChannels          Json?                   @map("care_notify_channels")
  careCloseConditions         Json?                   @map("care_close_conditions")

  // Phase user-create-with-zalo 2026-05-27 — config dùng cho welcome message tự động
  // khi admin tạo sale mới. Admin sửa toàn bộ template trong UI Thông báo hệ thống,
  // BE substitute placeholder {{fullName}}/{{phone}}/{{password}}/... lúc gửi.
  // Ảnh upload 1 lần, dùng cho mọi tin login. SĐT admin fallback nhận credentials
  // khi tin gửi sale fail (để admin chuyển thủ công).
  welcomeMessageTemplate String? @map("welcome_message_template") @db.Text
  welcomeImageUrl        String? @map("welcome_image_url")
  adminFallbackPhone     String? @map("admin_fallback_phone")

  // Lịch hẹn → Nhắc hẹn Zalo (2026-06-16): bật đẩy Nhắc hẹn Zalo cho sale qua nick hệ thống
  // + delay (phút) gửi tin "link đánh dấu hoàn thành/huỷ" SAU giờ hẹn (admin chỉnh trong Cài đặt lịch hẹn).
  appointmentZaloReminderEnabled Boolean @default(false) @map("appointment_zalo_reminder_enabled")
  appointmentActionDelayMinutes  Int     @default(15)    @map("appointment_action_delay_minutes")
  // 2026-06-18 "Nhắc 3 lần": mảng KHOẢNG CÁCH (interval) giữa các lần nhắc, đơn vị GIỜ.
  // [1,3,6] = nhắc lần 1 ở +1h, lần 2 ở +4h, lần 3 ở +10h (cộng dồn) sau giờ hẹn. Validate 3 phần tử, 0<v≤168.
  appointmentReminderOffsetsHours Json @default("[1, 3, 6]") @map("appointment_reminder_offsets_hours")
  // Digest trưởng phòng dừng sau N ngày kể từ lần digest đầu (Luật D2). 0 = không bao giờ dừng.
  appointmentDigestStopDays      Int  @default(7) @map("appointment_digest_stop_days")

  // Wave 2 Welcome Probe 2026-05-29 — config send welcome msg sau friend accept
  welcomeDelayAfterFriendReqSec Int     @default(60) @map("welcome_delay_after_friend_req_sec")
  welcomeStrangerInboxEnabled   Boolean @default(true) @map("welcome_stranger_inbox_enabled")
  welcomeMaxRetries             Int     @default(2) @map("welcome_max_retries")
  welcomeHardFailStops          Boolean @default(true) @map("welcome_hard_fail_stops")

  // ── #3 2026-06-06 (Anh chốt): Cài đặt kỹ thuật cấp tổ chức (admin) ──
  // Nhóm tham số VẬN HÀNH nội bộ — trước đây hardcode rải rác trong sweepers /
  // nick-worker. Đưa ra trang "Cài đặt kỹ thuật" cho admin, KHÔNG trộn vào wizard
  // tạo Mục tiêu. Default = đúng giá trị hardcode cũ để không đổi hành vi.
  // Nhịp quét các bộ dọn nền (giây).
  autoStuckSweepSeconds     Int @default(60) @map("auto_stuck_sweep_seconds")
  autoDrainerSweepSeconds   Int @default(30) @map("auto_drainer_sweep_seconds")
  autoWelcomeProbeSeconds   Int @default(10) @map("auto_welcome_probe_seconds")
  autoRemindSweepMinutes    Int @default(30) @map("auto_remind_sweep_minutes")
  // Ngưỡng coi 1 KH là "kẹt" trong lúc xử lý (phút) + số lần cứu tối đa.
  autoStuckThresholdMinutes Int @default(5) @map("auto_stuck_threshold_minutes")
  autoStuckMaxRecovery      Int @default(10) @map("auto_stuck_max_recovery")
  // Ngưỡng coi 1 chiến dịch bị treo (giờ) + reset KH khi nick offline lâu (giờ).
  autoCampaignTimeoutHours  Int @default(24) @map("auto_campaign_timeout_hours")
  autoNickOfflineResetHours Int @default(24) @map("auto_nick_offline_reset_hours")

  // Phase Tag Taxonomy v2 2026-05-31 (M57 /plan-eng-review Big-Bang Refactor)
  // Schema mới Tag + TagGroup + FriendTag + ContactTag chạy song song với CrmTag/CrmTagGroup
  // trong Wave 1-4 (dual-write). Drop legacy Wave 5.
  tagsV2      Tag[]
  tagGroupsV2 TagGroup[]

  // Phase Lead Pool 2026-05-24 — reverse relations
  leadRequests            LeadRequest[]
  leadPoolConfig          LeadPoolConfig?
  // Phase Lead Pool admin reset 2026-05-28
  leadPoolBonusQuotas     LeadPoolBonusQuota[]
  leadPoolDistributions   LeadPoolDistribution[]
  // Phase Multi-Source Lead Ads 2026-05-27
  facebookPageAccounts    FacebookPageAccount[]
  // 2026-06-06 (Anh chốt) — trần SDK mặc định hệ thống (9 category, áp cho mọi nick).
  sdkLimits               SdkLimit[]
  // Phase FB Lead Ads "Form" 2026-06-09 — port từ main (ingest lead qua Facebook Lead Form).
  facebookPageConnections FacebookPageConnection[]
  facebookFormMappings    FacebookFormMapping[]
  // Phase FB 2-tab 2026-06-10 — config FB App per-org (điền qua UI, fallback env).
  facebookAppConfig       FacebookAppConfig?
  // Phase Media Library 2026-06-11 — kho phương tiện (ảnh/album/file/video) + dedup.
  mediaBlobs              MediaBlob[]
  mediaAssets             MediaAsset[]
  mediaAlbums             MediaAlbum[]
  mediaUsageEvents        MediaUsageEvent[]

  @@map("organizations")
}

// Team groups within an organization
model Team {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@map("teams")
}

// CRM user with role-based access
model User {
  id                           String               @id @default(uuid())
  orgId                        String               @map("org_id")
  teamId                       String?              @map("team_id")
  // Phase Onboarding v1 2026-05-24 — email optional (sale VN dùng SĐT là chính, ít/không có email).
  // Unique partial: NULL không vi phạm constraint, 2 user cùng null OK.
  email                        String?              @unique
  passwordHash                 String               @map("password_hash")
  fullName                     String               @map("full_name")
  // RBAC Phase Phân Quyền 2026-05-21: legacy `role` còn giữ cho dual-read window 2 tuần,
  // mã mới đọc `permissionGroupId`. Sau migration verify OK (~2 tuần) → drop legacy column.
  role                         String               @default("member") // legacy: owner, admin, member
  permissionGroupId            String?              @map("permission_group_id")
  permissionGroup              PermissionGroup?     @relation(fields: [permissionGroupId], references: [id], onDelete: SetNull)
  departmentMember             DepartmentMember?
  // Phase Riêng Tư — visual privacy gate cho main nicks của user.
  // @deprecated 2026-06-06: chuyển sang OTP qua Zalo, KHÔNG còn PIN. privacyPinHash thành
  //   dead column (giữ tạm, migration drop để task dọn riêng). privacyFailedCount/LockedUntil
  //   VẪN DÙNG cho OTP (sai 5 lần → lock 30 phút).
  privacyPinHash               String?              @map("privacy_pin_hash")
  privacyFailedCount           Int                  @default(0) @map("privacy_failed_count")
  privacyLockedUntil           DateTime?            @map("privacy_locked_until")
  privacySessions              UserPrivacySession[]
  // Phase Privacy v2 2026-05-23 — hard cap số nick user được flip sang 'main' (privacyMode).
  // Default 2, admin sửa qua /users/:id/max-privacy-nicks. BE reject 400 khi vượt.
  maxPrivacyNicks              Int                  @default(2) @map("max_privacy_nicks")
  // Phase Privacy v2 2026-05-23 — nick "liên lạc nội bộ" — sale chọn 1 nick mình OWN làm
  // địa chỉ nhận system notification (miss KH msg, mention, alert). FK SET NULL khi reassign owner.
  internalContactZaloAccountId String?              @map("internal_contact_zalo_account_id")
  internalContactNick          ZaloAccount?         @relation("UserInternalContact", fields: [internalContactZaloAccountId], references: [id], onDelete: SetNull)
  // Phase Internal Contact 2-method 2026-05-23 — sale chọn 1 trong 2 cách nhận system notification:
  //   'crm_nick'       = dùng nick OWN (lưu ở internalContactZaloAccountId)
  //   'personal_phone' = nhập SĐT Zalo cá nhân không có trong CRM (lưu ở internalContactPhone, normalize 84xxx)
  // null = chưa setup. setupAt = lúc init handshake, confirmedAt = lúc gõ verify code đúng.
  internalContactMethod        String?              @map("internal_contact_method")
  internalContactPhone         String?              @map("internal_contact_phone")
  internalContactSetupAt       DateTime?            @map("internal_contact_setup_at")
  internalContactConfirmedAt   DateTime?            @map("internal_contact_confirmed_at")
  // Phase Onboarding v1 2026-05-24 — first-run setup tracker.
  // passwordChangedAt = null → FORCE đổi password lần đầu. User cũ backfill = createdAt.
  // onboardingStepsCompleted = JSON map { step: ISO timestamp | 'skipped' }.
  //   Keys: change_password, connect_nick, internal_contact, pin.
  // onboardingDismissedAt = sale ẩn checklist → collapse thành mini indicator.
  // jwtTokenVersion = bump khi đổi password → revoke JWT cũ (middleware check claim 'tv').
  passwordChangedAt            DateTime?            @map("password_changed_at")
  onboardingStepsCompleted     Json?                @map("onboarding_steps_completed")
  onboardingDismissedAt        DateTime?            @map("onboarding_dismissed_at")
  jwtTokenVersion              Int                  @default(0) @map("jwt_token_version")
  // Phase Onboarding v1 2026-05-24 — SĐT làm identifier đăng nhập chính cho sale VN.
  // Sale ít/không dùng email → admin tạo user chỉ với phone + password tạm. Login chấp
  // nhận cả email vừa phone (normalize 84xxx). Email vẫn giữ cho admin/owner + user cũ.
  phone                        String?              @unique
  // Phase user-create-with-zalo 2026-05-27 — avatar lấy từ Zalo nick của sale lúc tạo
  // (findUser response trả `avatar` URL). Hiển thị trong UsersRbacView name column.
  avatarUrl                    String?              @map("avatar_url")
  // Phase status 4-state 2026-05-27 — set lúc login thành công, derive "Im lặng" (>3d) vs "Hoạt động".
  // null = chưa từng login (phối hợp với passwordChangedAt=null để hiện "Chưa kích hoạt").
  lastLoginAt                  DateTime?            @map("last_login_at")
  isActive                     Boolean              @default(true) @map("is_active")
  createdAt                    DateTime             @default(now()) @map("created_at")
  updatedAt                    DateTime             @updatedAt @map("updated_at")

  org                       Organization                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team                      Team?                        @relation(fields: [teamId], references: [id])
  zaloAccounts              ZaloAccount[]
  zaloAccess                ZaloAccountAccess[]
  assignedContacts          Contact[]                    @relation("AssignedContacts")
  contactAccess             ContactAccess[]
  appointments              Appointment[]
  statusChangedAppointments Appointment[]                @relation("AppointmentStatusChanger")
  repliedMessages           Message[]                    @relation("RepliedMessages")
  activityLogs              ActivityLog[]
  messageTemplates          MessageTemplate[]
  authoredNotes             Note[]                       @relation("NoteAuthor")
  noteReactions             NoteReaction[]
  preferences               UserPreference[]
  // Phase 6+ — Inbox Triage Filter (per-user)
  accountFolders            AccountFolder[]
  savedFilterPresets        SavedFilterPreset[]
  // Phase 7 — Automation framework (createdBy backrefs)
  createdBlocks             Block[]                      @relation("BlockCreatedBy")
  createdBlockFolders       BlockFolder[]                @relation("BlockFolderCreatedBy")
  ownedBlockFolders         BlockFolder[]                @relation("BlockFolderOwnerUser")
  createdMessageTemplates   MessageTemplate[]            @relation("MessageTemplateCreatedBy")
  createdMTFolders          MessageTemplateFolder[]      @relation("MTFolderCreatedBy")
  ownedMTFolders            MessageTemplateFolder[]      @relation("MTFolderOwnerUser")
  createdSequences          AutomationSequence[]         @relation("SequenceCreatedBy")
  createdTriggers           AutomationTrigger[]          @relation("TriggerCreatedBy")
  createdBroadcasts         AutomationBroadcast[]        @relation("BroadcastCreatedBy")
  // Phase metrics layer 2026-05-22 — phone search by user
  phoneSearchEvents         PhoneSearchEvent[]
  systemNotifyRecipients    SystemNotifyRecipient[]
  systemNotifications       SystemNotification[]
  // Phase Lead Pool 2026-05-24
  leadRequests              LeadRequest[]
  // Phase Lead Pool admin reset 2026-05-28
  leadBonusReceived         LeadPoolBonusQuota[]         @relation("LeadPoolBonusRecipient")
  leadBonusGranted          LeadPoolBonusQuota[]         @relation("LeadPoolBonusGranter")
  leadDistributionsReceived LeadPoolDistribution[]       @relation("LeadDistributionRecipient")
  // Phase Privacy OTP 2026-05-27
  privacyOtpTokens          PrivacyOtpToken[]            @relation("PrivacyOtpUser")
  // M53 (2026-05-30): AI suggestions sale applied
  aiSuggestionsApplied      AiSuggestionApplied[]
  // Phase 2 bảo mật 2026-06-08 — refresh token rotation
  refreshTokens             RefreshToken[]
  // Mobile App 2026-06-15 — thiết bị nhận push (FCM/APNs)
  devices                   Device[]
  // Phase FB Lead Ads "Form" 2026-06-09 — round-robin chia lead cho sale.
  customerListAssignments   CustomerListSaleAssignment[]
  // Phase Media Library 2026-06-11 — kho phương tiện (owner + người tạo).
  ownedMediaAssets          MediaAsset[]                 @relation("MediaAssetOwner")
  createdMediaAssets        MediaAsset[]                 @relation("MediaAssetCreatedBy")
  ownedMediaAlbums          MediaAlbum[]                 @relation("MediaAlbumOwner")
  createdMediaAlbums        MediaAlbum[]                 @relation("MediaAlbumCreatedBy")

  @@map("users")
}

// Phase 2 bảo mật xác thực 2026-06-08 — refresh token rotation.
// Access token sống ngắn (15'); refresh token opaque random sống dài (30d),
// LƯU HASH (sha256) chứ không lưu plaintext. Mỗi lần dùng -> xoay (single-use):
// cấp token mới cùng familyId, đánh dấu token cũ usedAt + replacedById.
// Reuse-detection: token đã dùng (ngoài grace window) bị gửi lại -> coi là đánh
// cắp -> revoke CẢ family. KHÔNG có cột org_id -> không dính RLS (lookup theo
// tokenHash chạy pre-auth khi chưa biết org).
model RefreshToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  // sha256(token) hex — không bao giờ lưu plaintext.
  tokenHash    String    @unique @map("token_hash")
  // Nhóm xoay vòng: mọi token sinh từ một lần login chia sẻ familyId.
  familyId     String    @map("family_id")
  expiresAt    DateTime  @map("expires_at")
  // usedAt != null -> đã xoay (single-use). revokedAt != null -> bị thu hồi.
  usedAt       DateTime? @map("used_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id")
  // Device/session binding metadata (#7).
  createdIp    String?   @map("created_ip")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// Zalo account linked to a user (one user may own multiple Zalo accounts)
model ZaloAccount {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  ownerUserId     String    @map("owner_user_id")
  zaloUid         String?   @unique @map("zalo_uid")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  status          String    @default("disconnected") // connected, disconnected, qr_pending
  proxyUrl        String?   @map("proxy_url") // per-account proxy (PR#11)
  sessionData     Json?     @map("session_data")
  lastConnectedAt DateTime? @map("last_connected_at")
  // 2026-06-16 (Anh chốt): phân biệt NGẮT THỦ CÔNG vs MẤT KẾT NỐI THỤ ĐỘNG.
  //   disconnectedAt    = thời điểm nick rời trạng thái connected (mốc để FE đếm/hiển thị).
  //   disconnectReason  = 'manual' (sale bấm Ngắt → KHÔNG tự reconnect, hiện "Đã ngắt lúc {giờ}")
  //                     | 'passive' (nick rớt do Zalo/mạng → FE đếm phút:giây tăng) | null (đang connected).
  // Cron health-check + autoReconnect BỎ QUA nick disconnectReason='manual' (ngắt là ngắt thật).
  disconnectedAt    DateTime? @map("disconnected_at")
  disconnectReason  String?   @map("disconnect_reason")
  // Phase Riêng Tư 2026-05-22: sale gắn nick là 'main' → blur content cho user khác,
  // chỉ owner unlock PIN xem được. Default 'sub' (org public). Xem design doc:
  // ~/.gstack/projects/zalocrm/thanh-private-mode-design-20260521.md
  privacyMode     String    @default("sub") @map("privacy_mode")
  // 2026-06-09 (Anh chốt): xóa MỀM — sale/admin xóa nick khỏi danh sách nhưng GIỮ
  // dữ liệu (hội thoại/tin/bạn bè) trong DB. archivedAt != null = đã ẩn khỏi danh sách.
  // Listener + health-check BỎ QUA nick đã archive (không reconnect).
  archivedAt      DateTime? @map("archived_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org                Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner              User                  @relation(fields: [ownerUserId], references: [id])
  access             ZaloAccountAccess[]
  conversations      Conversation[]
  dailyStats         DailyMessageStat[]
  friendshipAttempts FriendshipAttempt[]
  friends            Friend[]
  zaloLabelsList     ZaloLabel[]
  crmTagGroups       CrmTagGroup[]
  // Phase 6+ — Inbox Triage Filter (junction folder membership)
  folderMembers      AccountFolderMember[]
  // Phase 7 — Automation framework
  ownedBlocks        Block[]               @relation("BlockOwnerNick")
  ownedBlockFolders  BlockFolder[]         @relation("BlockFolderOwnerNick")
  // assignedTasks   AutomationTask[]      @relation("TaskAssignedNick")  ← REMOVED 2026-06-01 Luồng Mục Tiêu M0

  // Phase 7 — Per-nick automation caps (configurable, default theo memory rule:
  //   300 msg/day/nick, 30-50 friend-add/day/nick)
  dailyFriendAddCap       Int       @default(30) @map("daily_friend_add_cap")
  dailyMessageCap         Int       @default(300) @map("daily_message_cap")
  // Per-nick throttle gate cross-campaign (memory: project_zalocrm_per_nick_throttle_gate)
  lastFriendReqSentAt     DateTime? @map("last_friend_req_sent_at")
  lastMessageSentAt       DateTime? @map("last_message_sent_at")
  // Phase Friend Invite 2026-05-28 — stranger message cap riêng (anh chốt 300/ngày default)
  dailyStrangerMessageCap Int       @default(300) @map("daily_stranger_message_cap")
  lastStrangerMessageAt   DateTime? @map("last_stranger_message_at")

  // Phase ZaloAccounts redesign 2026-05-22: status log để tính uptime thật.
  // Xem design doc: ~/.gstack/projects/zalocrm/EVO-THANH-private-hs-design-20260522-184345.md
  statusLogs                       ZaloAccountStatusLog[]
  // Phase metrics layer 2026-05-22 — phone search log per nick
  phoneSearchEvents                PhoneSearchEvent[]
  // Phase Privacy v2 2026-05-23 — reverse relations
  internalContactForUsers          User[]                  @relation("UserInternalContact")
  systemNotifyForOrgs              Organization[]          @relation("OrgSystemNotify")
  systemNotifyRecipientsAsSender   SystemNotifyRecipient[] @relation("SystemNotifySender")
  systemNotifyRecipientsAsInternal SystemNotifyRecipient[] @relation("SystemNotifyInternalContact")
  systemNotificationsAsSender      SystemNotification[]    @relation("SystemNotificationSender")
  systemNotificationsAsInternal    SystemNotification[]    @relation("SystemNotificationInternalContact")
  // 2026-06-06 (Anh chốt) — trần SDK ghi đè riêng per-nick (NULL = theo org default).
  sdkLimits                        SdkLimit[]
  // 2026-06-15 — ảnh kho lưu từ chat của nick này (để hiện "ảnh từ nick nào").
  mediaAssetsAsSource              MediaAsset[]            @relation("MediaAssetSourceNick")
  // 2026-06-18 — Cầu Zalo↔Telegram: cấu hình cầu per-nick (1 nick = 1 supergroup).
  telegramBridge                   TelegramBridgeConfig?

  @@map("zalo_accounts")
}

// 2026-06-06 (Anh chốt) — Trần an toàn SDK Zalo, cấu hình được (thay CATEGORY_LIMITS hardcode).
// 1 bảng cho CẢ org default LẪN nick override:
//   - zaloAccountId = NULL  → trần MẶC ĐỊNH HỆ THỐNG (áp cho mọi nick của org).
//   - zaloAccountId = <id>  → trần GHI ĐÈ riêng cho nick đó.
// Quy tắc đọc (Anh chốt): ưu tiên giá trị của nick; nick không có → dùng org default;
// org cũng chưa cấu hình loại đó → fallback hằng số code (DEFAULT_SDK_LIMITS).
// MỌI nơi gọi SDK (automation/trigger/sequence/broadcast qua zalo-rate-limiter) đọc từ đây.
model SdkLimit {
  id            String  @id @default(uuid())
  orgId         String  @map("org_id")
  zaloAccountId String? @map("zalo_account_id") // NULL = org default; có giá trị = nick override
  category      String // 'message'|'reaction'|'chat_action'|'group_admin'|'group_read'|'friend_action'|'friend_read'|'profile'|'query'
  dailyLimit    Int     @map("daily_limit")
  burstLimit    Int     @map("burst_limit")
  burstWindowMs Int     @default(30000) @map("burst_window_ms")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  nick ZaloAccount? @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  // Uniqueness do 2 PARTIAL unique index trong migration đảm bảo (Postgres):
  //   - sdk_limits_org_default_key  : UNIQUE(org_id, category) WHERE zalo_account_id IS NULL
  //   - sdk_limits_nick_override_key: UNIQUE(zalo_account_id, category) WHERE zalo_account_id IS NOT NULL
  // Không dùng @@unique của Prisma vì nó coi mỗi NULL là khác nhau → không chặn trùng org-default.
  // Service đọc/ghi qua findFirst + update/create (không upsert composite).
  @@index([orgId, zaloAccountId])
  @@map("sdk_limits")
}

// Phase ZaloAccounts redesign 2026-05-22 — event log + checkpoint hybrid.
// MỖI lần status đổi (zaloPool emit) hook writeTransition() → close record cũ
// (UPDATE endedAt=NOW WHERE endedAt IS NULL) + insert record mới (endedAt=NULL).
// Cron 5p checkpoint dùng zaloPool.getAllStatuses() reconcile orphan open records
// sau crash. Uptime = SUM(connected duration) / window × 100.
model ZaloAccountStatusLog {
  id        String    @id @default(uuid())
  orgId     String    @map("org_id")
  accountId String    @map("account_id")
  // 'connected' | 'disconnected' | 'auth_failed' | 'qr_pending' | 'expired'
  status    String
  startedAt DateTime  @map("started_at")
  // NULL = đang giữ status này. Đúng 1 record/account có endedAt=NULL ở mọi thời điểm.
  endedAt   DateTime? @map("ended_at")
  // 'login' | 'qr_scan' | 'reconnect_ok' | 'reconnect_failed' | 'disconnect'
  // | 'auth_fail' | 'session_expired' | 'crash_recovery' | 'checkpoint' | 'manual'
  reason    String?
  createdAt DateTime  @default(now()) @map("created_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account ZaloAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Query window uptime: WHERE accountId=? AND (endedAt IS NULL OR endedAt > since)
  @@index([accountId, startedAt])
  // Org-wide aggregate (team uptime)
  @@index([orgId, startedAt])
  // Find open record per account (partial index would be ideal — Prisma không hỗ trợ inline)
  @@index([accountId, endedAt])
  @@map("zalo_account_status_log")
}

// ACL: which users can access which Zalo accounts
model ZaloAccountAccess {
  id            String   @id @default(uuid())
  zaloAccountId String   @map("zalo_account_id")
  userId        String   @map("user_id")
  permission    String   @default("read") // read, chat, admin
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

// CRM contact record — generic pipeline with status field
model Contact {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloUid          String?   @map("zalo_uid")
  // Zalo identifiers toàn cục — KHÔNG đổi giữa các account viewer (khác với zaloUid per-account).
  // Dùng làm khóa dedup chính: cùng person từ 2 account CRM khác nhau có cùng zaloGlobalId.
  zaloGlobalId     String?   @map("zalo_global_id")
  zaloUsername     String?   @map("zalo_username")
  phone            String?
  // Canonical SĐT (84xxx no +/space) — auto-derive từ `phone` qua normalizePhone()
  // trên mọi write path. Index để search exact O(log n), dedup chính xác cross-format
  // (0xxx ↔ 84xxx ↔ +84xxx cùng map về 84xxx). Hiện chỉ index phone chính; phone2/3
  // vẫn search via contains variants vì ít dùng.
  phoneNormalized  String?   @map("phone_normalized")
  email            String?   @map("email")
  fullName         String?   @map("full_name")
  crmName          String?   @map("crm_name")
  avatarUrl        String?   @map("avatar_url")
  source           String? // FB, TT, GT, CN, phone_import, etc.
  sourceDate       DateTime? @map("source_date")
  firstContactDate DateTime? @map("first_contact_date")
  status           String?   @default("new") // LEGACY: new/contacted/interested/converted/lost — giữ 1 release, sau drop. Field mới: statusId FK -> Status table
  statusId         String?   @map("status_id")
  // ── Parent-Child (KH cha gom nhiều KH con — cross-Zalo-identity human-level link) ───
  // Khác mergedInto (hard-merge same Zalo identity, secondary hidden): parentContactId
  // soft-link, child visible, aggregate status/score/hasZalo từ children. Canonical son
  // làm cha → parentContactId=NULL cho cha, các con khác trỏ về.
  parentContactId  String?   @map("parent_contact_id")
  nextAppointment  DateTime? @map("next_appointment")
  assignedUserId   String?   @map("assigned_user_id")
  notes            String?
  tags             Json      @default("[]") // CRM tags do sale gắn ("vip","quan_tam_3pn",...). Auto tag prefix "auto:"
  metadata         Json      @default("{}")
  leadScore        Int       @default(0) @map("lead_score")
  lastActivity     DateTime? @map("last_activity")
  mergedInto       String?   @map("merged_into")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // ── Discovery via friend-request attempt ─────────────────────────────────
  hasZalo            Boolean?  @map("has_zalo") // null=unknown, true=verified yes, false=verified no
  zaloLookupAt       DateTime? @map("zalo_lookup_at")
  zaloLookupAttempts Int       @default(0) @map("zalo_lookup_attempts")
  importBatchId      String?   @map("import_batch_id") // soft FK -> phone_list_imports.id (model later)

  // ── Compliance ─────────────────────────────────────────────────────────────
  consentStatus    String    @default("implicit") @map("consent_status") // implicit/granted/revoked
  consentRevokedAt DateTime? @map("consent_revoked_at")
  consentSource    String?   @map("consent_source") // form_landing, opt_in_msg, manual, ...

  // ── Multi-phone ────────────────────────────────────────────────────────────
  phone2      String? @map("phone_2")
  phone3      String? @map("phone_3")
  phonesExtra Json    @default("[]") @map("phones_extra") // [{phone,label},...]

  // ── Demographic / BĐS profile ──────────────────────────────────────────────
  province       String?
  district       String?
  ward           String?
  addressLine    String?   @map("address_line")
  gender         String? // male/female/other/unknown
  // 2026-06-18: true khi sale chỉnh giới tính TAY → sync SDK (zinstant/cron) KHÔNG đè ngược.
  genderLocked   Boolean   @default(false) @map("gender_locked")
  birthYear      Int?      @map("birth_year")
  birthDate      DateTime? @map("birth_date") @db.Date
  occupation     String?
  incomeRange    String?   @map("income_range")
  socialFacebook String?   @map("social_facebook")
  socialTiktok   String?   @map("social_tiktok")
  preferredLang  String?   @default("vi") @map("preferred_lang")

  // ── Aggregate: tin nhắn cuối từ KHÁCH (inbound) ───────────────────────────
  lastInboundAt        DateTime? @map("last_inbound_at")
  lastInboundMessageId String?   @map("last_inbound_message_id")
  lastInboundPreview   String?   @map("last_inbound_preview")
  lastInboundType      String?   @map("last_inbound_type")

  // ── Aggregate: tin nhắn cuối từ SALE (outbound) ───────────────────────────
  lastOutboundAt              DateTime? @map("last_outbound_at")
  lastOutboundMessageId       String?   @map("last_outbound_message_id")
  lastOutboundPreview         String?   @map("last_outbound_preview")
  lastOutboundType            String?   @map("last_outbound_type")
  lastOutboundByUserId        String?   @map("last_outbound_by_user_id") // soft FK
  lastOutboundByZaloAccountId String?   @map("last_outbound_by_zalo_account_id") // soft FK

  // ── Aggregate: tương tác cuối (reaction/recall/edit/...) ──────────────────
  lastInteractionAt      DateTime? @map("last_interaction_at")
  lastInteractionType    String?   @map("last_interaction_type")
  lastInteractionPayload Json?     @map("last_interaction_payload")

  // ── Counters (cache) ───────────────────────────────────────────────────────
  totalInbound      Int @default(0) @map("total_inbound")
  totalOutbound     Int @default(0) @map("total_outbound")
  totalAppointments Int @default(0) @map("total_appointments")

  org               Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedUser      User?               @relation("AssignedContacts", fields: [assignedUserId], references: [id])
  mergedIntoContact Contact?            @relation("ContactMerge", fields: [mergedInto], references: [id])
  mergedFrom        Contact[]           @relation("ContactMerge")
  parent            Contact?            @relation("ContactFather", fields: [parentContactId], references: [id], onDelete: SetNull)
  children          Contact[]           @relation("ContactFather")
  statusRef         Status?             @relation(fields: [statusId], references: [id], onDelete: SetNull)
  conversations     Conversation[]
  appointments      Appointment[]
  attempts          FriendshipAttempt[]
  friends           Friend[]
  // Phase Contact Scope Hybrid 2026-05-27 — collaborator share (primary + collaborator).
  // 1 Contact có thể có nhiều User cùng truy cập (1 primary + N collaborator) khi cả
  // 2 sale dùng nick riêng cùng chăm 1 KH. Visibility helper getContactScope() dùng
  // bảng này thay vì chỉ assignedUserId.
  contactAccess     ContactAccess[]
  contactNotes      Note[]
  // Phase 7 — Automation framework
  // automationTasks   AutomationTask[]  ← REMOVED 2026-06-01 Luồng Mục Tiêu M0
  // Phase Lead Pool 2026-05-24
  leadRequests      LeadRequest[]
  // Phase Lead Pool FIFO 2026-06-15 — vòng tua công bằng (thay điểm số + random).
  // lastPooledAt = NULL nghĩa CHƯA từng chia qua pool → ưu tiên đầu vòng tuyệt đối.
  // pooledCount = số lần đã chia (đếm vòng). ORDER BY (pooledCount ASC, lastPooledAt
  // ASC NULLS FIRST, created_at, id) cho FIFO: lead mới đầu vòng, đã chia/trả xuống cuối.
  lastPooledAt        DateTime?               @map("last_pooled_at")
  pooledCount         Int                     @default(0) @map("pooled_count")
  leadDistributions   LeadPoolDistribution[]

  // Per-Contact counters (cache from Friend rows; updated by friend-aggregate hooks)
  acceptedNicksCount Int @default(0) @map("accepted_nicks_count")
  pendingNicksCount  Int @default(0) @map("pending_nicks_count")
  chattingNicksCount Int @default(0) @map("chatting_nicks_count")

  // ── Phase 6: Aggregate Lead Scoring fields ─────────────────────────────
  // Aggregated từ Friend rows. Trigger: sau mỗi Friend.score thay đổi.
  // Logic: Contact.leadScore = MAX(Friend.leadScore), aggregateBreakdown =
  // breakdown của Friend có leadScore cao nhất, ownerFriendId trỏ tới đó.
  // Render: Manager view / dashboard / list dùng Contact.leadScore.
  // Sale view (chat panel cột 3-4) dùng Friend.leadScore của nick đang active.
  aggregateScoreUpdatedAt DateTime? @map("aggregate_score_updated_at")
  // ownerFriendId: Friend.id có leadScore cao nhất + inbound recent 14d.
  // Soft FK (không enforce qua relation) vì Friend cascade-delete sẽ NULL cell này.
  ownerFriendId           String?   @map("owner_friend_id")
  aggregateBreakdown      Json      @default("{}") @map("aggregate_breakdown")
  // autoTags aggregated: UNION từ tất cả Friend.autoTags, dedupe.
  autoTags                Json      @default("[]") @map("auto_tags")
  // stuckSinceAggregate: MIN(Friend.stuckSince) khi TẤT CẢ Friend đều stuck.
  // Nếu có ít nhất 1 Friend không stuck → null (KH vẫn có "đường" qua nick khác).
  stuckSinceAggregate     DateTime? @map("stuck_since_aggregate")

  // ── Phase 8: Engagement Heatmap Timeline ────────────────────────────────
  // Pattern classification derived từ ContactEngagementDaily 4-week rolling window.
  // Updated bởi daily cron 02:30 VN time.
  // Values: hot | champion | stable | cooling | cold | noise (chưa đủ data)
  engagementPattern   String?   @map("engagement_pattern")
  // Trend % change tuần này vs tuần trước (-100 to +∞, clamp display -100..200)
  engagementTrend     Int?      @map("engagement_trend")
  // Avg dailyIntensity 28 days (0-100). Snapshot quality.
  engagementScore     Int?      @map("engagement_score")
  engagementUpdatedAt DateTime? @map("engagement_updated_at")

  // ── Phase 8.C: Priority Score (combined) ───────────────────────────────
  // Formula: leadScore × 0.55 + engagementScore × 0.30 + trendBoost
  // trendBoost: engagementTrend ≥ 20 → +10; ≤ -20 → -5; else 0
  // Clamp 0-100. Recompute trên mỗi lead/engagement update + daily cron.
  priorityScore     Int?      @map("priority_score")
  priorityUpdatedAt DateTime? @map("priority_updated_at")

  // Wave 2 Welcome Probe 2026-05-29 — last welcome sent (after friend accept)
  // LEGACY 2026-06-02: display hint only (last welcome ever). Dedup source of truth
  // moved to FriendRequestOutbox (contactId, triggerId) — per-(contact, trigger) semantic.
  // Written for compat, NEVER read by the welcome gate. Do not re-introduce reads on this column.
  welcomeSentAt  DateTime? @map("welcome_sent_at")
  welcomeChannel String?   @map("welcome_channel") // friend_msg | stranger_inbox

  // Daily engagement aggregate rows (cascade delete)
  engagementDaily ContactEngagementDaily[]

  // M53 (2026-05-30): AI suggestions applied to this Contact (virtual chat assistant)
  aiSuggestionsApplied AiSuggestionApplied[]

  // Phase Tag Taxonomy v2 2026-05-31 (M57) — junction TagContact (Big-Bang Refactor).
  // Chạy song song Contact.tags JSON cho dual-write Wave 3-4.
  tagAssignments ContactTag[]

  @@unique([orgId, zaloGlobalId])
  @@index([orgId, phone])
  @@index([orgId, phoneNormalized])
  @@index([orgId, zaloUid])
  // Default sort cho ContactsView list: tương tác mới nhất lên đầu.
  // Cần index để tránh seq scan khi 4500+ contacts.
  @@index([orgId, lastActivity])
  @@index([orgId, priorityScore(sort: Desc)])
  @@index([orgId, zaloUsername])
  @@index([orgId, mergedInto])
  @@index([orgId, hasZalo])
  @@index([orgId, importBatchId])
  @@index([orgId, consentStatus])
  @@index([orgId, province, district])
  @@index([orgId, lastInboundAt])
  @@index([orgId, lastOutboundAt])
  @@index([orgId, status, lastInboundAt])
  @@index([phone2])
  @@index([phone3])
  @@index([orgId, acceptedNicksCount])
  @@index([orgId, parentContactId])
  @@index([orgId, statusId])
  // Phase Lead Pool FIFO 2026-06-15 — index phục vụ ORDER BY vòng tua. Prisma không
  // khai báo được NULLS FIRST trong @@index → migration SQL tự thêm tay (xem migration).
  @@index([orgId, pooledCount, lastPooledAt])
  // Phase 6 aggregate indexes
  @@index([orgId, leadScore(sort: Desc)])
  @@index([orgId, stuckSinceAggregate])
  @@index([orgId, aggregateScoreUpdatedAt(sort: Desc)])
  @@map("contacts")
}

// Status (Trạng thái KH) — per-org config replacing Contact.status enum cũ.
// Default seed 8 status: Mới/Tiếp cận/Hẹn gặp/Nóng/Tiềm năng/Chốt/Thất Bại/Mất.
// `order` Int: dùng cho aggregation Cha = MAX(sons.status.order).
// `isTerminal`: status kết thúc (Chốt/Thất Bại/Mất) — UI có thể style khác.
// `isDefault`: 1 status được flag default cho Contact mới (Mới).
model Status {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  name       String
  order      Int      @default(0)
  color      String?
  isTerminal Boolean  @default(false) @map("is_terminal")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts Contact[]
  friends  Friend[]

  @@unique([orgId, name])
  @@index([orgId, order])
  @@map("statuses")
}

// A chat thread between a Zalo account and a contact (or group)
model Conversation {
  id                String    @id @default(uuid())
  orgId             String    @map("org_id")
  zaloAccountId     String    @map("zalo_account_id")
  contactId         String?   @map("contact_id")
  threadType        String    @default("user") // user, group
  externalThreadId  String?   @map("external_thread_id")
  // Group-specific (chỉ set khi threadType=group; resolve qua getGroupInfo từ zca-js)
  groupName         String?   @map("group_name")
  groupAvatarUrl    String?   @map("group_avatar_url")
  groupMembersCount Int?      @map("group_members_count")
  lastMessageAt     DateTime? @map("last_message_at")
  unreadCount       Int       @default(0) @map("unread_count")
  isReplied         Boolean   @default(true) @map("is_replied")
  tab               String    @default("main") @map("tab") // main, other
  // M53 (2026-05-30): Virtual conversation cho KH no-Zalo. isVirtual=true → chat-routes skip
  // Zalo SDK send, lưu thẳng Message isLocal=true. externalThreadId synthetic 'virtual:{contactId}:{nickId}'.
  // Memory M53: anh chốt Approach A — sale có 1 chỗ duy nhất xem TẤT CẢ KH trong /chat.
  isVirtual         Boolean   @default(false) @map("is_virtual")
  // 2026-06-11 — Xóa mềm hội thoại từ cột 2 (anh chốt: ẩn đi, khôi phục được).
  // Khi != null → mọi query list/count loại trừ. KHÔNG xóa Message vật lý.
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  org           Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount   ZaloAccount          @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact       Contact?             @relation(fields: [contactId], references: [id])
  messages      Message[]
  aiSuggestions AiSuggestion[]
  pins          PinnedConversation[]
  // 2026-06-18 — Cầu Telegram: 1 hội thoại = 1 forum topic (định tuyến reply).
  telegramTopic TelegramTopicMap?

  @@unique([zaloAccountId, externalThreadId])
  @@index([orgId, zaloAccountId, isReplied, lastMessageAt])
  @@index([orgId, zaloAccountId, lastMessageAt])
  @@index([orgId, tab, lastMessageAt])
  @@index([orgId, deletedAt])
  // M-tier tab-switch fix (2026-05-21): index riêng cho tab Cá Nhân/Nhóm
  // (filter theo threadType + accountId, sort lastMessageAt desc).
  // Trước fix: planner seq-scan + filter post-index → 1-3s lag chuyển tab.
  @@index([orgId, threadType, zaloAccountId, lastMessageAt(sort: Desc)])
  // Tab Chính/Khác: filter tab + accountId, sort lastMessageAt desc.
  @@index([orgId, tab, zaloAccountId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

// Individual message within a conversation
model Message {
  id                  String    @id @default(uuid())
  conversationId      String    @map("conversation_id")
  zaloMsgId           String?   @map("zalo_msg_id")
  // Numeric Snowflake từ Zalo server — primary sort key (match 100% Zalo Web).
  // sentAt giữ làm display + fallback cho CRM-sent chưa echo. KHÔNG dùng sentAt làm
  // primary order vì self-listen events đôi khi thiếu `ts` → Date.now() fallback lệch ~30s.
  zaloMsgIdNum        BigInt?   @map("zalo_msg_id_num")
  senderType          String    @map("sender_type") // self, contact
  senderUid           String?   @map("sender_uid")
  senderName          String?   @map("sender_name")
  content             String?
  contentType         String    @default("text") @map("content_type") // text, image, file, sticker, voice, video, link
  attachments         Json      @default("[]")
  quote               Json?     @map("quote")
  albumKey            String?   @map("album_key") // Zalo group_layout_id — identifies multi-image albums
  albumIndex          Int?      @map("album_index") // 0-based position within album
  albumTotal          Int?      @map("album_total") // total items in album
  isDeleted           Boolean   @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at")
  // Edit message audit (2026-05-21) — zca-js không support edit thật, edit chỉ áp dụng trên CRM.
  // Khi sửa: lưu content cũ vào originalContent (lần đầu) + set editedAt = now.
  originalContent     String?   @map("original_content")
  editedAt            DateTime? @map("edited_at")
  // Zalo client message id (2026-05-21) — KHÁC zaloMsgId (server snowflake). Cần cho api.undo
  // (Zalo expect cả msgId + cliMsgId). Tin cũ trước migration chưa có column này → null.
  zaloCliMsgId        String?   @map("zalo_cli_msg_id")
  sentAt              DateTime  @map("sent_at")
  // Read receipts (2026-05-21 Wave 1+2 — wire `delivered_messages` + `seen_messages`
  // SDK events). Cả 2 chỉ set cho tin OUTGOING (senderType='self'); KH-side luôn null.
  //   deliveredAt — Zalo server confirm device KH đã nhận packet (1 tick xám)
  //   seenAt      — KH mở conversation đọc tin (2 tick xanh)
  deliveredAt         DateTime? @map("delivered_at")
  seenAt              DateTime? @map("seen_at")
  repliedByUserId     String?   @map("replied_by_user_id")
  // Phase metrics layer 2026-05-22: phân biệt nguồn gửi cho automation rate-limit + dashboard.
  // 'user' = sale gửi qua CRM UI HOẶC sync về từ Zalo native (default — backward compat)
  // 'automation' = bot/sequence/broadcast/NBA suggest gửi qua engine
  // 'system' = CRM internal (reminder card, system notice — chưa dùng, reserved)
  sentVia             String    @default("user") @map("sent_via")
  // M53 (2026-05-30): isLocal=true cho message KHÔNG gửi qua Zalo SDK (virtual conv hoặc AI assistant).
  // Worker/metrics/automation aggregator phải filter WHERE isLocal=false. zaloMsgId synthetic 'local:{cuid}' để né NULL collision.
  // senderType có thêm value 'ai_assistant' khi AI trợ lý reply trong virtual chat.
  // metadata Json lưu extracted entities AI suggest: { extracted: {...}, confidenceScore, missingFields }
  //   + M11 (2026-06-02): metadata.sender = { kind, name, detail?, sequenceId?, stepIdx? }
  isLocal             Boolean   @default(false) @map("is_local")
  metadata            Json?
  // ── Mention metadata Anh chốt 2026-06-03 ──
  // Persist Zalo SDK TGroupMessage.mentions để FE render chính xác theo
  // pos+len thay vì đoán regex. Chỉ group message có mentions; user 1-1 null.
  // Shape: [{ uid: string; pos: number; len: number; type: 0 | 1 }]
  //   pos = vị trí ký tự @ trong content
  //   len = độ dài full mention (kèm cả " - Hs Holding")
  //   type = 0=user | 1=all (@all)
  mentions            Json?
  // ── Luồng Mục Tiêu M10/M11 attribution 2026-06-01 ──
  // automationTaskId = BullMQ jobId (string, KHÔNG FK vì AutomationTask đã drop).
  // Pattern: `${triggerId}-${contactId}-${stepIdx}` (DASH, BullMQ v5 cấm `:` — POC 2026-06-01).
  // automationStepIndex = bước thứ mấy trong sequence (1,2,3...) cho per-step funnel M10.
  automationTaskId    String?   @map("automation_task_id")
  automationStepIndex Int?      @map("automation_step_index")
  // Mobile App 2026-06-15 (BE-3) — idempotency: uuid app tự sinh, gửi 1 lần / 1 tin.
  // Dedup TRƯỚC khi gửi sang Zalo (zaloMsgId chỉ có SAU khi Zalo trả về → quá muộn cho retry).
  clientEchoId        String?   @map("client_echo_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  repliedBy    User?             @relation("RepliedMessages", fields: [repliedByUserId], references: [id])
  reactions    MessageReaction[]

  @@unique([conversationId, zaloMsgId])
  // BE-3 idempotency — 1 echoId duy nhất / conversation. Multiple NULL cho phép (tin cũ).
  @@unique([conversationId, clientEchoId])
  @@index([conversationId, albumKey])
  // Composite index cho sort theo Zalo Snowflake — primary order khi list messages.
  @@index([conversationId, zaloMsgIdNum(sort: Desc)])
  // Phase metrics 2026-05-22: aggregate query per nick per day per category
  @@index([conversationId, sentAt, senderType, sentVia])
  // M10/M11 — attribution + filter
  @@index([automationTaskId, sentAt])
  @@index([sentVia, conversationId])
  @@map("messages")
}

// ── Cầu Zalo ↔ Telegram (2026-06-18) ──────────────────────────────────────────
// 1 nick = 1 cấu hình cầu = 1 supergroup Telegram. enabled=false tới khi owner bật.
// telegramChatId NULL tới khi tài khoản công ty provision xong group (Phase 3).
// Chống lặp KHÔNG dùng cột source: khử trùng selfListen echo theo zaloMsgId (Phase 2).
model TelegramBridgeConfig {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  zaloAccountId  String   @unique @map("zalo_account_id") // 1 nick = 1 config
  telegramChatId String?  @map("telegram_chat_id") // supergroup id (set khi provision)
  enabled        Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@index([orgId, enabled])
  @@map("telegram_bridge_config")
}

// 1 hội thoại (KH) = 1 forum topic trong supergroup của nick — định tuyến reply 2 chiều.
model TelegramTopicMap {
  id              String   @id @default(uuid())
  conversationId  String   @unique @map("conversation_id")
  telegramChatId  String   @map("telegram_chat_id") // supergroup chứa topic
  telegramTopicId Int      @map("telegram_topic_id") // forum topic id (message_thread_id)
  // Cho chính sách đóng topic im lặng > N ngày khi đụng trần ~1000 topic/supergroup.
  lastActiveAt    DateTime @default(now()) @map("last_active_at")
  createdAt       DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([telegramChatId, lastActiveAt])
  @@map("telegram_topic_map")
}

// Phase metrics layer 2026-05-22 — Phone search event log.
// Mỗi lần POST /zalo-accounts/:id/find-user log 1 row. Phone hash SHA-256 cho privacy.
// Dùng cho dashboard "Phone search today: total/found/notfound" + Automation rate-limit.
model PhoneSearchEvent {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  accountId  String   @map("account_id") // nick nào search
  userId     String?  @map("user_id") // user trigger (null nếu automation)
  phoneHash  String   @map("phone_hash") // SHA-256 SĐT — privacy + dedup
  // 'found_zalo' | 'no_zalo' | 'rate_limited' | 'error'
  result     String
  foundUid   String?  @map("found_uid") // null khi result != 'found_zalo'
  errorCode  String?  @map("error_code")
  occurredAt DateTime @default(now()) @map("occurred_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account ZaloAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id])

  @@index([accountId, occurredAt])
  @@index([orgId, occurredAt])
  @@index([phoneHash])
  @@map("phone_search_events")
}

model SystemNotifyRecipient {
  id                           String    @id @default(uuid())
  orgId                        String    @map("org_id")
  targetUserId                 String    @map("target_user_id")
  senderZaloAccountId          String?   @map("sender_zalo_account_id")
  internalContactZaloAccountId String?   @map("internal_contact_zalo_account_id")
  conversationId               String?   @map("conversation_id")
  threadIdInSenderView         String?   @map("thread_id_in_sender_view")
  status                       String    @default("invalid")
  error                        String?
  lastVerifiedAt               DateTime  @default(now()) @map("last_verified_at")
  // Phase Internal Contact 2-method 2026-05-23 — verify code 4 số sau handshake.
  // Status flow mở rộng: pending_friend_request → pending_user_confirm → ready.
  // verifyCode = hash 4 số sale phải gõ lại; expire 30 phút; lock sau 5 lần sai.
  verifyCode                   String?   @map("verify_code")
  verifyCodeExpiresAt          DateTime? @map("verify_code_expires_at")
  verifyAttempts               Int       @default(0) @map("verify_attempts")
  // Lưu request UID (UID của bên kia từ góc nhìn nick gửi friend request) để retry/cancel.
  friendRequestSentAt          DateTime? @map("friend_request_sent_at")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  targetUser          User         @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  senderZaloAccount   ZaloAccount? @relation("SystemNotifySender", fields: [senderZaloAccountId], references: [id], onDelete: SetNull)
  internalContactNick ZaloAccount? @relation("SystemNotifyInternalContact", fields: [internalContactZaloAccountId], references: [id], onDelete: SetNull)

  @@unique([targetUserId, senderZaloAccountId])
  // FIX codex review HIGH-1 2026-05-27: chống race khi 2 admin map cùng UID cho 2 user khác nhau.
  // Postgres cho phép multiple NULL trong unique → recipient chưa setup (thread null) không bị block.
  @@unique([senderZaloAccountId, threadIdInSenderView])
  @@index([orgId, status])
  @@index([senderZaloAccountId, status])
  @@map("system_notify_recipients")
}

// Mobile App 2026-06-15 (BE-1) — thiết bị đăng ký nhận push notification.
// 1 fcmToken = 1 hàng (unique). userId/orgId lấy từ JWT, KHÔNG nhận từ body.
// deviceId ổn định theo máy (đổi token vẫn giữ) — dùng dọn token cũ cùng máy.
model Device {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  orgId      String   @map("org_id")
  fcmToken   String   @unique @map("fcm_token") // token Google FCM / Apple APNs
  platform   String   // 'ios' | 'android'
  deviceId   String   @map("device_id") // định danh máy (ổn định)
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

model SystemNotification {
  id                           String    @id @default(uuid())
  orgId                        String    @map("org_id")
  type                         String
  title                        String
  content                      String    @db.Text
  priority                     String    @default("normal")
  senderZaloAccountId          String?   @map("sender_zalo_account_id")
  targetUserId                 String    @map("target_user_id")
  internalContactZaloAccountId String?   @map("internal_contact_zalo_account_id")
  recipientId                  String?   @map("recipient_id")
  conversationId               String?   @map("conversation_id")
  channel                      String    @default("crm_panel")
  status                       String    @default("pending")
  zaloMsgId                    String?   @map("zalo_msg_id")
  error                        String?
  createdAt                    DateTime  @default(now()) @map("created_at")
  sentAt                       DateTime? @map("sent_at")

  org                 Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  targetUser          User         @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  senderZaloAccount   ZaloAccount? @relation("SystemNotificationSender", fields: [senderZaloAccountId], references: [id], onDelete: SetNull)
  internalContactNick ZaloAccount? @relation("SystemNotificationInternalContact", fields: [internalContactZaloAccountId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt(sort: Desc)])
  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([orgId, status, createdAt(sort: Desc)])
  @@map("system_notifications")
}

// Appointment scheduled for a contact
// source='zalo' khi sync từ reminder Zalo client, source='manual' khi sale tạo trong CRM.
// externalRef = Zalo reminderId (unique per org để dedup khi reminder edit/fire lại).
// zaloMessageId = FK mềm tới Message.id của reminder card → deep-link conversation.
model Appointment {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  assignedUserId  String?  @map("assigned_user_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String?  @map("appointment_time")
  // 2026-05-21 "Nhắc hẹn" refactor — anh chốt 1 modal cho create+edit:
  //   title       — tiêu đề (default = "Gọi nhắc KH X")
  //   durationMin — dự kiến dành thời gian (phút), endAt tính ngầm = startAt + duration
  //   location    — địa điểm (5 preset chips + smart suggest từ title)
  //   type        — 4 values: call | message | meeting | follow_up
  title           String?
  durationMin     Int      @default(15) @map("duration_min")
  location        String?
  type            String?
  status          String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes           String?
  reminderSent    Boolean  @default(false) @map("reminder_sent")
  // 2026-06-16: đã gửi tin "link đánh dấu hoàn thành/huỷ" (sau giờ hẹn) chưa — LEGACY (cron cũ set true 1 lần).
  // 2026-06-18 đổi sang đếm: giữ cột này để migration cũ không vỡ, logic mới đọc actionPromptCount.
  actionPromptSent Boolean @default(false) @map("action_prompt_sent")
  // 2026-06-18 "Nhắc 3 lần + digest trưởng phòng":
  //   actionPromptCount    — đã gửi nhắc mấy lần (0..3); cron tăng SAU khi gửi OK (Luật D4).
  //   lastActionPromptAt   — mốc gửi nhắc gần nhất.
  //   managerDigestedAt    — lần cuối đưa lịch này vào digest trưởng phòng (chống gửi lại trong ngày).
  //   managerDigestFirstAt — lần ĐẦU vào digest; dừng digest sau Organization.appointmentDigestStopDays ngày (Luật D2).
  actionPromptCount    Int       @default(0) @map("action_prompt_count")
  lastActionPromptAt   DateTime? @map("last_action_prompt_at")
  managerDigestedAt    DateTime? @map("manager_digested_at")
  managerDigestFirstAt DateTime? @map("manager_digest_first_at")
  createdAt       DateTime @default(now()) @map("created_at")

  // Nguồn + link Zalo
  source        String  @default("manual") // "manual" | "zalo"
  externalRef   String? @map("external_ref") // Zalo reminderId (params.actions[0].data.reminderId)
  zaloMessageId String? @map("zalo_message_id") // FK mềm → Message.id (không cascade, giữ data nếu msg xoá)
  emoji         String? // ⏰ 🔔 từ params hoặc default

  // Status audit — track ai đổi status cuối cùng + lúc nào (cron auto-flip không set)
  statusChangedByUserId String?   @map("status_changed_by_user_id")
  statusChangedAt       DateTime? @map("status_changed_at")
  statusChangedBy       User?     @relation("AppointmentStatusChanger", fields: [statusChangedByUserId], references: [id])

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])
  fromNotes    Note[]       @relation("NoteAppointment")
  actionLinks  AppointmentActionLink[]

  @@unique([orgId, externalRef])
  @@index([source])
  @@index([orgId, appointmentDate])
  @@map("appointments")
}

// 2026-06-18 — Short-link cho tin "Nhắc hoàn thành lịch hẹn". 1 mã ngắn / 1 lịch (tái dùng cả 3 lần nhắc).
// GET /a/:code → kiểm expiresAt → mint action token (exp=min(7d, expiresAt)) → 302 sang /appointments/action?t=
// Nguồn chân lý hết-hạn là cột expiresAt ở đây, KHÔNG phải TTL token (chống mỗi lần bấm đẻ token 7 ngày mới).
model AppointmentActionLink {
  code          String   @id // base62 ngắn (7-8 ký tự)
  appointmentId String   @map("appointment_id")
  orgId         String   @map("org_id")
  userId        String   @map("user_id") // sale được quyền cập nhật (đưa vào token payload)
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_action_links")
}

// CRM-style notes on a contact — Facebook-comment-like with flat thread (parentNoteId nullable, depth=1).
// Manager có thể reply vào note của sale. Reaction emoji per (note, user, emoji).
// AI có thể parse note body ("Thứ 6 gọi lại khách") → suggest Appointment (linked via Appointment.noteId).
model Note {
  id                     String   @id @default(uuid())
  orgId                  String   @map("org_id")
  contactId              String   @map("contact_id")
  parentNoteId           String?  @map("parent_note_id") // null = root note, set = reply (chỉ 1 cấp)
  authorUserId           String   @map("author_user_id")
  body                   String   @db.Text
  // Khi user bấm "🤖 Tạo lịch hẹn" trên note → set FK tới appointment được tạo.
  // Cho phép hiện badge "đã tạo lịch" trên note + tránh tạo trùng.
  suggestedAppointmentId String?  @map("suggested_appointment_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact     Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author      User           @relation("NoteAuthor", fields: [authorUserId], references: [id])
  parent      Note?          @relation("NoteThread", fields: [parentNoteId], references: [id], onDelete: Cascade)
  replies     Note[]         @relation("NoteThread")
  reactions   NoteReaction[]
  appointment Appointment?   @relation("NoteAppointment", fields: [suggestedAppointmentId], references: [id], onDelete: SetNull)

  @@index([orgId, contactId, createdAt])
  @@index([parentNoteId])
  @@map("notes")
}

// CRM tag — tag SYSTEM-LEVEL do org tự định nghĩa (vd "vip", "quan_tâm", "hot_lead").
// Khác ZaloLabel (Zalo native, sync 2-way với Zalo SDK).
// Contact.tags JSON array of strings tham chiếu CrmTag.name. Nếu name không match
// trong CrmTag table → vẫn cho lưu (free-text) nhưng FE hint user thêm vào table.
model CrmTag {
  id                String    @id @default(uuid())
  orgId             String    @map("org_id")
  name              String // unique per org, dùng làm reference key
  color             String    @default("#90A4AE") // hex color
  emoji             String? // optional unicode emoji prefix
  description       String? // mô tả mục đích, vd "Khách quan tâm dự án EGV"
  category          String? // LEGACY: gom nhóm string-based. Mới: dùng groupId
  groupId           String?   @map("group_id") // FK CrmTagGroup — gom nhóm formal
  managedBy         String?   @map("managed_by") // null | 'zalo_sync' — Zalo-managed tag read-only trong UI CRM
  sourceZaloLabelId Int?      @map("source_zalo_label_id") // ZaloLabel.zaloLabelId nếu managedBy='zalo_sync'
  archivedAt        DateTime? @map("archived_at") // soft delete khi Zalo label bị xoá
  order             Int       @default(0) // sort order trong settings
  isActive          Boolean   @default(true) @map("is_active")
  usageCount        Int       @default(0) @map("usage_count") // denorm — cập nhật khi recompute
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  group CrmTagGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([orgId, name])
  @@unique([sourceZaloLabelId]) // 1 Zalo label → 1 CrmTag mirror
  @@index([orgId, category])
  @@index([orgId, groupId])
  @@index([managedBy, archivedAt])
  @@map("crm_tags")
}

// Tag group — gom các CrmTag thuộc cùng "nhóm" (formal hơn category string).
// 2 use case: (1) user-defined group, (2) zalo-managed group auto-tạo từ Zalo nick.
// managedBy='zalo_sync' + zaloAccountId set → group được tạo+maintain tự động khi sync.
model CrmTagGroup {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  name          String // vd "Zalo - Phạm Thành CSKH (0912345678)" hoặc "Mức độ"
  managedBy     String?   @map("managed_by") // null | 'zalo_sync'
  zaloAccountId String?   @map("zalo_account_id") // set nếu managedBy='zalo_sync'
  order         Int       @default(0)
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount? @relation(fields: [zaloAccountId], references: [id], onDelete: SetNull)
  tags        CrmTag[]

  @@unique([orgId, name])
  @@unique([zaloAccountId, managedBy]) // 1 Zalo account chỉ có 1 zalo_sync group
  @@index([orgId, archivedAt])
  @@map("crm_tag_groups")
}

// ═════════════════════════════════════════════════════════════════════════════
// TAG TAXONOMY v2 — M57 /plan-eng-review Big-Bang Refactor (2026-05-31)
// ═════════════════════════════════════════════════════════════════════════════
// Gom 12 layer tag rải rác thành 2 nhóm: Friend Tag (per-pair) + CRM Tag (cấp KH).
// 4 bảng mới: Tag (definition) + TagGroup (formal grouping) + FriendTag (junction
// Friend × Tag) + ContactTag (junction Contact × Tag). Chạy song song legacy 5
// cols (Contact.tags, Friend.crmTagsPerNick/zaloLabels/autoTags, Contact.autoTags)
// trong Wave 3-4 dual-write, drop Wave 5.
//
// Scope split: TagScope.friend (per-pair sale × KH — Zalo Real, manual per-nick,
// auto detect/score/engagement) vs TagScope.crm (cấp Contact — manual CRM, AI
// suggest, segment rule, status workflow, import).

enum TagScope {
  friend
  crm
}

enum TagSource {
  zalo_real // Friend scope only — sync 2-way Zalo native label
  manual_per_nick // Friend scope — sale gắn per nick
  auto_detect // Friend scope — system auto (active/stuck/cold/...)
  auto_score // Friend scope — derive leadScore tier (A/B/C/D)
  auto_engagement // Friend scope — derive engagementPattern
  manual_crm // CRM scope — sale gắn cấp KH
  ai_suggest // CRM scope — AI Trợ Lý extract entity (M55)
  segment_rule // CRM scope — admin-defined segment auto-apply
  status // CRM scope — workflow status
  import // CRM scope — bulk import CSV/Excel
}

// Tag definition — source of truth cho name, color, group, priority.
// Constraint enforce trong migration SQL:
//   - CHECK scope+source invariant (Issue 1A)
//   - 2 partial unique (Issue 2A): zaloAccountId IS NULL vs NOT NULL
//   - 3 perf indexes (Issue 9A): friend_id, tag_id, (slug, source) partial
model Tag {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  name        String // hiển thị: "VIP", "Khách Q4", "BĐS Hot"
  slug        String // normalized: slugifyTag(name)
  color       String    @default("#90A4AE")
  emoji       String?
  description String?
  scope       TagScope
  source      TagSource
  priority    Int       @default(99) // 1=top, 99=bottom

  // Group cha (optional) — replace CrmTagGroup.
  groupId String? @map("group_id")

  // Zalo sync metadata — chỉ set khi source=zalo_real.
  // zaloAccountId NULL cho scope=crm + scope=friend(manual_per_nick/auto_*).
  zaloAccountId     String? @map("zalo_account_id")
  sourceZaloLabelId Int?    @map("source_zalo_label_id")

  // Auto-tag metadata — chỉ relevant source=auto_*.
  autoRule String? @map("auto_rule") // vd "leadScore >= 80"

  archivedAt DateTime? @map("archived_at")
  usageCount Int       @default(0) @map("usage_count")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  group              TagGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  friendAssignments  FriendTag[]
  contactAssignments ContactTag[]

  // Partial unique indexes định nghĩa trong migration SQL (Prisma không support trực tiếp):
  //   CREATE UNIQUE INDEX tags_org_scope_slug_uniq ON tags(org_id, scope, slug) WHERE zalo_account_id IS NULL;
  //   CREATE UNIQUE INDEX tags_org_account_label_uniq ON tags(org_id, zalo_account_id, source_zalo_label_id) WHERE zalo_account_id IS NOT NULL;

  @@index([orgId, scope])
  @@index([orgId, groupId])
  @@index([archivedAt])
  // Perf index Wave 1 (Issue 9A) — partial WHERE archivedAt IS NULL trong migration SQL.
  @@map("tags")
}

// Group cha (replace CrmTagGroup) — formal grouping vd "Mức độ", "Dự án quan tâm".
model TagGroup {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  name       String
  scope      TagScope
  order      Int       @default(0)
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tags Tag[]

  @@unique([orgId, scope, name])
  @@index([orgId, scope])
  @@map("tag_groups")
}

// Junction Friend × Tag (replace crmTagsPerNick + zaloLabels + autoTags 3 cols).
// Soft delete: removedAt + removedBy (audit trace).
model FriendTag {
  id        String    @id @default(uuid())
  friendId  String    @map("friend_id")
  tagId     String    @map("tag_id")
  addedBy   String?   @map("added_by") // userId nếu manual, null nếu auto/worker
  addedVia  TagSource @map("added_via") // enum match TagSource
  addedAt   DateTime  @default(now()) @map("added_at")
  removedAt DateTime? @map("removed_at")
  removedBy String?   @map("removed_by")

  friend Friend @relation(fields: [friendId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([friendId, tagId])
  // Perf index Wave 1 (Issue 9A) — partial WHERE removed_at IS NULL trong migration SQL.
  @@index([friendId, removedAt])
  @@index([tagId, removedAt])
  @@map("friend_tags")
}

// Junction Contact × Tag (replace Contact.tags JSON).
model ContactTag {
  id        String    @id @default(uuid())
  contactId String    @map("contact_id")
  tagId     String    @map("tag_id")
  addedBy   String?   @map("added_by")
  addedVia  TagSource @map("added_via")
  addedAt   DateTime  @default(now()) @map("added_at")
  removedAt DateTime? @map("removed_at")
  removedBy String?   @map("removed_by")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId, removedAt])
  @@index([tagId, removedAt])
  @@map("contact_tags")
}

// Per-user preferences (timeline filter, UI toggles, ...).
// Key/value JSON store, scoped userId. Cross-device sync khi user đăng nhập máy khác.
model UserPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String // vd "timeline.categories.visible"
  value     Json     @default("null")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preferences")
}

// Zalo native labels — synced từ Zalo SDK getLabels() per nick.
// 1 label = (zaloAccountId, zaloLabelId). conversations[] là list externalThreadId
// được assign label đó. Update qua SDK updateLabels({labelData, version}).
// Settings page hiển thị bảng + cho phép edit color/text → write back qua SDK.
model ZaloLabel {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  zaloAccountId String   @map("zalo_account_id")
  zaloLabelId   Int      @map("zalo_label_id") // numeric ID từ Zalo
  textKey       String   @map("text_key") // SDK textKey field
  text          String // tên label hiển thị
  color         String // hex from SDK
  emoji         String? // unicode emoji
  offset        Int      @default(0) // sort order trong Zalo client
  version       Int      @default(0) // server-version của bulk
  conversations Json     @default("[]") // string[] externalThreadId
  createTime    BigInt?  @map("create_time") // SDK epoch
  syncedAt      DateTime @default(now()) @map("synced_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, zaloLabelId])
  @@index([orgId, zaloAccountId])
  @@map("zalo_labels")
}

// Emoji reaction trên 1 note. 1 user có thể reaction nhiều emoji khác nhau, không trùng cùng 1 emoji.
model NoteReaction {
  id        String   @id @default(uuid())
  noteId    String   @map("note_id")
  userId    String   @map("user_id")
  emoji     String // 1 emoji unicode: 👍 ❤️ 😂 😮 😢 🎉 ...
  createdAt DateTime @default(now()) @map("created_at")

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId, emoji])
  @@index([noteId])
  @@map("note_reactions")
}

// Audit trail — log MỌI mutation CRM với actor + category + diff.
// Source of truth cho timeline + activity log page.
// Actor 3 loại: user (sale/admin), bot (automation), system (migration/sync).
// Category 9 nhóm: customer_info, tags_crm, tags_zalo, status_care, score,
//   appointment, interaction, system, automation.
model ActivityLog {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  userId       String?  @map("user_id") // null nếu actorType != 'user'
  actorType    String   @default("user") @map("actor_type") // 'user' | 'bot' | 'system'
  botName      String?  @map("bot_name") // vd "AutoTag Bot" — chỉ khi actorType='bot'
  systemSource String?  @map("system_source") // vd "zalo_label_sync" — chỉ khi actorType='system'
  category     String? // 9 nhóm — null cho legacy rows
  action       String
  entityType   String?  @map("entity_type")
  entityId     String?  @map("entity_id")
  details      Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  // Composite indexes cho timeline query (entity per-customer) + activity log page
  // (filter category + date range). Sort DESC vì 99% query là "latest first".
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([orgId, category, createdAt(sort: Desc)])
  @@index([orgId, actorType, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// Daily messaging statistics per user per Zalo account
model DailyMessageStat {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  userId            String   @map("user_id")
  zaloAccountId     String   @map("zalo_account_id")
  statDate          DateTime @map("stat_date") @db.Date
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")
  messagesUnread    Int      @default(0) @map("messages_unread")
  messagesUnreplied Int      @default(0) @map("messages_unreplied")
  avgResponseTime   Int?     @map("avg_response_time_seconds")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

// External service integration (Google Sheets, Telegram, Facebook, Zapier)
model Integration {
