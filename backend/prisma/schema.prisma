// Group poll (ported from openzca group poll)
model GroupPoll {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  zaloAccountId   String    @map("zalo_account_id")
  groupExternalId String    @map("group_external_id")
  zaloPollId      String    @map("zalo_poll_id")
  question        String
  options         Json      @default("[]") // [{id, text, voteCount}]
  isMultiChoice   Boolean   @default(false) @map("is_multi_choice")
  isAnonymous     Boolean   @default(false) @map("is_anonymous")
  isLocked        Boolean   @default(false) @map("is_locked")
