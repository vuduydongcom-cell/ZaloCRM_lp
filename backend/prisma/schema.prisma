  @@map("group_polls")
}

// State machine for outreach: 1 nick × 1 contact = 1 attempt
// state: queued | looking_up | no_zalo | sent | accepted | rejected | cancelled | expired | error
model FriendshipAttempt {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  zaloAccountId String    @map("zalo_account_id")
  contactId     String    @map("contact_id")
  state         String    @default("queued")
  // 2026-06-09 — phân biệt sale gửi tay vs automation gửi (cột "Hôm nay" tách Bot/User).
  // 'user' = sale bấm tay, 'automation' = engine/campaign. Default 'automation' (đa số qua engine).
  source        String    @default("automation")
  zaloUidFound  String?   @map("zalo_uid_found")
  requestMsg    String?   @map("request_msg")
  errorCode     String?   @map("error_code")
  errorDetail   String?   @map("error_detail")
  queuedAt      DateTime  @default(now()) @map("queued_at")
  lookedUpAt    DateTime? @map("looked_up_at")
  sentAt        DateTime? @map("sent_at")
  decidedAt     DateTime? @map("decided_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, contactId])
  @@index([orgId, state])
  @@index([contactId, state])
  @@index([zaloAccountId, state, queuedAt])
  @@map("friendship_attempts")
}

// Per-(nick × KH) relationship row. Created when ANY of these occur:
//   - friend request accepted (zca-js friend_event ADD) → friendshipStatus=accepted
//   - friend request sent successfully → friendshipStatus=pending_sent
//   - friend request received (zca-js friend_event REQUEST, isSelf=false) → pending_received
//   - first message exchanged with KH not yet friend → hasConversation=true, friendshipStatus=none
// Drives both /friends UI (per-nick view) and Contact aggregate counters.
model Friend {
  id            String @id @default(uuid())
  orgId         String @map("org_id")
  contactId     String @map("contact_id")
  zaloAccountId String @map("zalo_account_id")
  zaloUidInNick String @map("zalo_uid_in_nick")

  // ── State (2 dimensions + 1 derived) ────────────────────────────────────
  friendshipStatus String  @default("none") @map("friendship_status")
  // none | pending_sent | pending_received | accepted | rejected | removed | blocked
  hasConversation  Boolean @default(false) @map("has_conversation")
  relationshipKind String  @default("none") @map("relationship_kind")
  // friend | pending_friend | chatting_stranger | ghost | none

  // ── Zalo-side metadata ──────────────────────────────────────────────────
  aliasInNick        String?   @map("alias_in_nick")
  // Tên + avatar Zalo của KH NHÌN TỪ NICK NÀY (per-identity).
  // Set khi message-handler dispatch tin → applyFriendAggregate. Dùng cho
  // FE hiển thị Friend row + promote-to-parent (new Contact name).
  zaloDisplayName    String?   @map("zalo_display_name")
  zaloAvatarUrl      String?   @map("zalo_avatar_url")
  // Globally-unique identifiers — về mặt bản chất thuộc Zalo identity per-Friend,
  // không thuộc Contact (KH Cha). Cùng Zalo identity nhìn từ nhiều nick có cùng
  // globalId/username (per-viewer chỉ khác zaloUidInNick). KH Cha aggregate qua
  // computeAggregateDisplay: trùng tất cả Friend → cha hiện chung; khác → "đa".
  zaloGlobalId       String?   @map("zalo_global_id")
  zaloUsername       String?   @map("zalo_username")
  zaloLabels         Json      @default("[]") @map("zalo_labels") // [{id,name,color}]
  zaloLabelsSyncedAt DateTime? @map("zalo_labels_synced_at")
  // Tag CRM per-pair — sale gắn tag RIÊNG cho cặp (nick này × KH này), KHÁC với
  // Contact.tags (cấp KH chung). Vd "ưu tiên với nick này", "đã follow-up từ
  // nick này". Format: ["tag1", "tag2", ...]. Tag Cha aggregate hiện ở
  // ChatContactPanel section "Tag CRM hệ thống cấp KH".
  crmTagsPerNick     Json      @default("[]") @map("crm_tags_per_nick")

  // ── Lifecycle timestamps ────────────────────────────────────────────────
  becameFriendAt DateTime? @map("became_friend_at")
  removedAt      DateTime? @map("removed_at")
  firstMessageAt DateTime? @map("first_message_at") // first message exchanged across this pair

  // ── Per-pair aggregates (set-if-newer / increment from message hooks) ──
  lastInboundAt     DateTime? @map("last_inbound_at")
  lastOutboundAt    DateTime? @map("last_outbound_at")
  lastInteractionAt DateTime? @map("last_interaction_at")
  totalInbound      Int       @default(0) @map("total_inbound")
  totalOutbound     Int       @default(0) @map("total_outbound")

  // Phase Contact Scope Hybrid 2026-05-27 — per-pair preview cho list KH render
  // theo "view của riêng nick này". Khi sale list /contacts, helper getContactScope
  // chọn preview của Friend row visible thay vì Contact.last*Preview aggregate global.
  // → Sale A thấy preview qua nick A1, Sale B thấy preview qua nick B1; không leak
  // chat của sale khác. Contact.last*Preview giữ làm cache cho admin/owner.
  lastInboundPreview    String? @map("last_inbound_preview")
  lastInboundType       String? @map("last_inbound_type")
  lastInboundMessageId  String? @map("last_inbound_message_id")
  lastOutboundPreview   String? @map("last_outbound_preview")
  lastOutboundType      String? @map("last_outbound_type")
  lastOutboundMessageId String? @map("last_outbound_message_id")

  // ── Per-pair CRM state (mỗi nick chăm có status + score RIÊNG) ────────
  // Contact (KH Cha) aggregate: displayStatus = MAX(friends.statusRef.order),
  // displayLeadScore = MAX(friends.leadScore), displayHasZalo = friends.length > 0.
  statusId  String? @map("status_id")
  statusRef Status? @relation(fields: [statusId], references: [id], onDelete: SetNull)
  leadScore Int     @default(0) @map("lead_score")

  // ── Phase 6: Lead Scoring Engine fields ────────────────────────────────
  // scoreBreakdown: cached 4-dim sub-scores cho Score Explainability Modal.
  // Shape: { engagement: 0-100, intent: 0-100, fit: 0-100, velocity: 0-100,
  //          computedAt: ISO, finalScore: 0-100 }
  // Mỗi recompute → ghi vào ActivityLog (category='score') với delta.
  scoreBreakdown Json      @default("{}") @map("score_breakdown")
  scoreUpdatedAt DateTime? @map("score_updated_at")
  // stuckSince: timestamp KH bị flag đình trệ (theo StuckThreshold per stage).
  // Cron daily 6am scan; set khi đạt threshold, clear khi có inbound mới.
  // Stuck Detection Dashboard filter `WHERE stuckSince IS NOT NULL`.
  stuckSince     DateTime? @map("stuck_since")
  // autoTags: metadata layer derived từ score + activity + stage.
  // Format: ["active","stuck","cold","ready","atrisk","rewarmed","frozen"]
  // Update qua autoTagCompute() khi score/stage/activity đổi.
  autoTags       Json      @default("[]") @map("auto_tags")
  // stageEnteredAt: timestamp khi friend chuyển vào stage hiện tại.
  // Dùng cho Stuck Detection (so với current time) + analytics (avg time per stage).
  stageEnteredAt DateTime? @map("stage_entered_at")

  // ── Sequence recode Đợt 1 (2026-06-13) — cột mềm nullable, D1 giữ schema ──
  // strangerBlocked: KH này tự bật quyền riêng tư "không nhận tin người lạ" trên Zalo.
  // Set true khi send-message nhận lỗi "User không nhận tin nhắn từ người lạ" → DỪNG
  // sequence riêng cặp (nick,KH) này (không spam lỗi lặp), báo sale cần kết bạn trước.
  // Clear khi KH chấp nhận kết bạn (friendshipStatus → accepted). NULL = chưa từng gặp.
  strangerBlocked   Boolean?  @map("stranger_blocked")
  strangerBlockedAt DateTime? @map("stranger_blocked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  // Phase Tag Taxonomy v2 2026-05-31 (M57) — junction FriendTag (Big-Bang Refactor).
  // Chạy song song Friend.crmTagsPerNick + zaloLabels + autoTags cho dual-write Wave 3-4.
  tagAssignments FriendTag[]

  // KHÔNG unique theo (zaloAccountId, contactId) vì 1 Contact (KH Cha) có thể có
  // nhiều Friend per cùng zaloAccount khi merge từ các Zalo identity khác nhau
  // của cùng person. Identity thật được enforce qua (zaloAccountId, zaloUidInNick).
  @@unique([zaloAccountId, zaloUidInNick])
  @@index([zaloAccountId, contactId])
  @@index([orgId, contactId])
  @@index([zaloAccountId, relationshipKind]) // /friends tab filtering
  @@index([zaloAccountId, friendshipStatus])
  @@index([orgId, relationshipKind])
  @@index([orgId, statusId])
  // Phase 6 indexes for scoring queries
  @@index([orgId, scoreUpdatedAt(sort: Desc)])
  @@index([orgId, stuckSince])
  @@index([orgId, leadScore(sort: Desc)])
  @@map("friends")
}

// Phase Contact Scope Hybrid 2026-05-27 — collaborator share table.
// Một KH (Contact) có thể được nhiều sale cùng chăm qua nhiều nick. Field
// Contact.assignedUserId chỉ giữ "primary owner" duy nhất, KHÔNG đủ để cover
// case 2-sale-cùng-chăm. ContactAccess bổ sung: mỗi cặp (Contact × User) 1 row,
// role={primary|collaborator}, source={manual|auto_from_friend|auto_from_assignment}.
//
// Helper getContactScope(userId) đọc bảng này để compute visibleContactIds.
// Auto-share hook: khi Friend row tạo mới (handshake hoặc applyFriendAggregate
// first-message) → upsert ContactAccess role=collaborator, source=auto_from_friend.
model ContactAccess {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  contactId String   @map("contact_id")
  userId    String   @map("user_id")
  role      String   @default("collaborator")
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contactId, userId])
  @@index([orgId, userId])
  @@index([orgId, contactId])
  @@map("contact_access")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 6 — Lead Scoring Engine (Config + Rules + Templates)
// ═══════════════════════════════════════════════════════════════════════════
// ScoringConfig: org-level weights + global settings cho Lead Scoring Engine.
// 1 row / orgId. Default seed khi org tạo lần đầu (xem seed.ts).
// Edit qua Settings UI (admin only). Phase 6 PR6.
model ScoringConfig {
  id    String @id @default(uuid())
  orgId String @unique @map("org_id")

  // ── Weights cho 4 sub-dimensions (tổng phải = 100) ────────────────────
  weightEngagement Int @default(35) @map("weight_engagement")
  weightIntent     Int @default(30) @map("weight_intent")
  weightFit        Int @default(15) @map("weight_fit")
  weightVelocity   Int @default(20) @map("weight_velocity")

  // ── Decay rules (silent → giảm điểm Engagement) ────────────────────────
  decayDay3to7   Int @default(-1) @map("decay_day_3_7") // -1/ngày
  decayDay7to14  Int @default(-3) @map("decay_day_7_14") // -3/ngày
  decayDay14to30 Int @default(-5) @map("decay_day_14_30") // -5/ngày
  decayDay30to60 Int @default(-8) @map("decay_day_30_60") // -8/ngày
  // Sau 60 ngày: drop to Frozen (override, không decay tiếp).

  // ── Global flags ──────────────────────────────────────────────────────
  // autoPromote: cho phép engine auto-promote stage khi đạt criteria.
  // Nếu false → chỉ manual promote.
  autoPromote           Boolean @default(true) @map("auto_promote")
  // stuckDetectionEnabled: bật/tắt cron daily phát hiện đình trệ.
  stuckDetectionEnabled Boolean @default(true) @map("stuck_detection_enabled")
  // explainabilityEnabled: lưu scoreBreakdown JSON cho UI explainability.
  // Disable cho org muốn save space (production thường để true).
  explainabilityEnabled Boolean @default(true) @map("explainability_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("scoring_configs")
}

// ScoreSignalRule: rules để compute từng tín hiệu (signal) thành delta điểm.
// Mỗi rule có signalKey (vd "ask_price", "appointment_complete") + delta + cap +
// dimension target (engagement/intent/fit/velocity). Engine load rules per-org,
// apply khi detect signal trong chat content hoặc action event.
//
// Default seed (xem seed.ts) match với CEO review design:
//   intent.ask_price: +15, intent.appointment_complete: +35, ...
//   engagement.inbound_message: +3 (cap +15/ngày), ...
//
// Admin có thể tune từ Settings UI (PR6).
model ScoreSignalRule {
  id        String @id @default(uuid())
  orgId     String @map("org_id")
  signalKey String @map("signal_key") // e.g. "ask_price", "inbound_message"
  // Dimension target: engagement/intent/fit/velocity. Engine cộng delta vào
  // sub-score tương ứng, sau aggregate qua weights → final score.
  dimension String

  // Detection rule type:
  //   keyword     — match keywords trong chat content (Vietnamese)
  //   action      — trigger từ event (appointment_create, appointment_complete...)
  //   silent      — silent decay (theo decayDay* trong config)
  //   profile     — set 1 lần khi profile match (budget/location/type)
  //   velocity    — compute weekly (3 ngày liên tiếp, trend up...)
  ruleType String @map("rule_type")

  // Delta điểm khi rule match. Positive = tăng, negative = giảm.
  delta Int

  // Cap per day (null = không giới hạn). Vd "inbound_message" cap +15/ngày.
  // Engine count signals/ngày, không apply nếu vượt cap.
  capPerDay Int? @map("cap_per_day")

  // Cap total (null = không giới hạn). Vd "first_inbound" chỉ apply 1 lần lifetime.
  capTotal Int? @map("cap_total")

  // Keywords config (chỉ áp dụng ruleType = "keyword"):
  // Format JSON: ["giá", "bao nhiêu", "rao bao nhiêu"] — match case-insensitive.
  keywords Json @default("[]")

  // Vietnamese label cho Score Explainability Modal hiển thị.
  // Vd "Hỏi giá rõ ràng", "Hoàn thành lịch xem nhà".
  label String

  // Stage applicability — rule chỉ apply khi friend ở stage này.
  // null = apply mọi stage. Stage names: "Mới", "Tiếp cận", "Hẹn gặp", ...
  applicableStages Json @default("[]") @map("applicable_stages")

  enabled Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, signalKey])
  @@index([orgId, ruleType, enabled])
  @@map("score_signal_rules")
}

// StageTransitionRule: criteria để auto-promote Friend giữa các stage.
// Mỗi row định nghĩa fromStage → toStage + criteria (JSON).
// Engine evaluate khi Friend.score thay đổi hoặc event xảy ra (appointment_create...).
//
// Default 7 rules (Mới→Tiếp cận, Tiếp cận→Hẹn gặp, ..., Tiềm năng→Chốt).
// Khi criteriaMatch + autoPromote=true → engine update statusId + stageEnteredAt,
// log ActivityLog với category='status_care', action='stage_promote_auto'.
//
// Manual promote (sale tự chuyển) → log với action='stage_promote_manual'.
model StageTransitionRule {
  id        String @id @default(uuid())
  orgId     String @map("org_id")
  fromStage String @map("from_stage") // tên Status (vd "Mới")
  toStage   String @map("to_stage") // tên Status (vd "Tiếp cận")

  // Criteria JSON shape: {
  //   minEngagement?: number,
  //   minIntent?: number,
  //   minFit?: number,
  //   minVelocity?: number,
  //   minInboundCount?: number,
  //   requiresAction?: string[],  // ["appointment_create"] | ["appointment_complete"]
  //   minDaysInStage?: number,
  //   requiresManualConfirm?: boolean
  // }
  criteria Json @default("{}")

  // Auto-apply hay cần manual confirm (vd Nóng → Tiềm năng cần sale verify).
  requiresManualConfirm Boolean @default(false) @map("requires_manual_confirm")

  enabled Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, fromStage, toStage])
  @@index([orgId, fromStage, enabled])
  @@map("stage_transition_rules")
}

// StuckThreshold: per-stage thresholds để phát hiện đình trệ.
// Cron daily 6am scan tất cả Friend, set stuckSince nếu đạt threshold.
// Stuck Detection Dashboard query `WHERE stuckSince IS NOT NULL` + group by stage.
//
// Default 5 thresholds:
//   Mới        > 7 ngày  → extra decay -2/ngày
//   Tiếp cận   > 14 ngày → extra decay -1/ngày
//   Hẹn gặp    > 30 ngày → đề xuất video call
//   Nóng       > 21 ngày → có ưu đãi tháng này
//   Tiềm năng  > 14 ngày → gọi điện trực tiếp
model StuckThreshold {
  id    String @id @default(uuid())
  orgId String @map("org_id")
  stage String // tên Status (vd "Mới", "Tiếp cận")

  // Số ngày tối thiểu trong stage để bị coi là đình trệ.
  thresholdDays Int @map("threshold_days")

  // Extra decay/ngày khi stuck (cộng dồn với decayDay* trong ScoringConfig).
  extraDecayPerDay Int @default(0) @map("extra_decay_per_day")

  // NBA template key — link tới NbaTemplate.
  // Khi UI render Stuck Detection card → fetch template + render personalized.
  nbaTemplateKey String? @map("nba_template_key")

  // Vietnamese label cho UI ("Cần liên hệ ngay", "Đề xuất video call", ...).
  alertLabel String @map("alert_label")

  enabled Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, stage])
  @@index([orgId, stage, enabled])
  @@map("stuck_thresholds")
}

// NbaTemplate: "Next Best Action" message templates.
// Render trong Stuck Detection Dashboard + Score Breakdown Modal.
// Sale 1-click "Gửi mẫu" → mở chat compose với template pre-filled (placeholders
// thay bằng KH name, dự án, ưu đãi tháng này).
//
// Default 7 templates (match Stuck Detection design):
//   - stuck_stage_new_greeting
//   - stuck_stage_approach_tour
//   - stuck_stage_meeting_videocall
//   - stuck_stage_hot_promo
//   - stuck_stage_potential_call
//   - cold_reengage_30d
//   - hot_close_push
model NbaTemplate {
  id              String @id @default(uuid())
  orgId           String @map("org_id")
  key             String // unique key (vd "stuck_stage_new_greeting")
  // Vietnamese label cho UI dropdown / list.
  label           String
  // Content template với placeholders:
  //   {{customerName}}  → KH.displayName
  //   {{projectName}}   → org dự án hiện tại (settings)
  //   {{promoMonth}}    → ưu đãi tháng này (settings)
  //   {{viewingLink}}   → 360° tour URL
  contentTemplate String @map("content_template")

  // Phân loại để filter trong UI Settings.
  // "stuck" | "cold_reengage" | "hot_close" | "general"
  category String @default("general")

  enabled Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@index([orgId, category, enabled])
  @@map("nba_templates")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 6+ — Inbox Triage Filters (AccountFolder + SavedFilterPreset)
// ═══════════════════════════════════════════════════════════════════════════

// AccountFolder — gom 2-3 ZaloAccount thành 1 "thư mục" tùy chỉnh per-user.
// UI Smax-style flat list (không cây): folder hiện composite avatar + tên + count.
// Click folder = chọn context filter (cùng style với "ALL toàn bộ").
// 1 ZaloAccount có thể nằm trong NHIỀU folder (junction model AccountFolderMember).
model AccountFolder {
  id     String @id @default(uuid())
  orgId  String @map("org_id")
  // Folder per-user (sale tự tổ chức) — không share giữa user trong cùng org.
  // Null = system-default folder (vd "ALL toàn bộ" — không cần row vì derived).
  userId String @map("user_id")

  name  String
  color String? @default("#6366F1") // hex màu accent cho folder

  // Order trong sidebar (sale drag-drop sắp xếp). Default order theo createdAt.
  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org     Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  members AccountFolderMember[]

  @@unique([userId, name])
  @@index([orgId, userId, sortOrder])
  @@map("account_folders")
}

// AccountFolderMember — junction: folder ↔ ZaloAccount (M:N).
// 1 account có thể trong nhiều folder cùng lúc (vd "Sales miền Bắc" + "Hot deals").
model AccountFolderMember {
  id            String @id @default(uuid())
  folderId      String @map("folder_id")
  zaloAccountId String @map("zalo_account_id")

  createdAt DateTime @default(now()) @map("created_at")

  folder      AccountFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount   @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([folderId, zaloAccountId])
  @@index([zaloAccountId])
  @@map("account_folder_members")
}

// SavedFilterPreset — combo filter user đã lưu để 1-click recall.
// Vd: "Sáng nay xử lý" = { unread: true, type: 'user', sortBy: 'unread-first' }
// UI render trong Cột 1 sau folder list (theo yêu cầu user).
model SavedFilterPreset {
  id     String @id @default(uuid())
  orgId  String @map("org_id")
  userId String @map("user_id")

  name       String
  emoji      String? @default("⭐") // emoji nhanh nhận diện (☀️ 🥶 🔥 📞)
  // filterJson lưu toàn bộ state filter: { folderId, saleAssigneeId, type,
  //   tabBox, quickPills: [...], tags: [...], timeAxis, timeRange, sortMode }
  filterJson Json    @map("filter_json")

  // Order vertical trong list. Default theo createdAt DESC (mới nhất trên cùng).
  sortOrder  Int       @default(0) @map("sort_order")
  // Last-used timestamp — để future feature "smart sort" theo recency.
  lastUsedAt DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([orgId, userId, sortOrder])
  @@map("saved_filter_presets")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 7 — Automation Framework
//
// Architecture (anh đã chốt 2026-05-20):
//   ─ Authoring layer (user tạo): BlockFolder → Block ← Sequence/Trigger/Broadcast
//   ─ Runtime layer (engine):     AutomationCampaign → AutomationTask
//   ─ Snapshot rule: AutomationTask.blockSnapshot frozen lúc enroll → edit Block
//     KHÔNG ảnh hưởng task đang chạy (có nút Re-sync để force update khi cần)
//   ─ Reuse: FriendshipAttempt cho request_friend action outcome log
//   ─ Channel focus phase này: 'zalo_user' (per-nick personal account)
// ═══════════════════════════════════════════════════════════════════════════

// Folder tổ chức Block — pattern smax.ai (folder theo sale: PHÚ, THÀNH, NGỌC...).
// `ownerNickId` optional: nếu bind 1 nick → block trong folder mặc định runtime
// dispatch qua nick đó. `ownerUserId` optional: folder cá nhân của 1 sale CRM.
// BlockFolder — Anh chốt 2026-06-04: visibility lưu ở Folder, KHÔNG ở Block.
// visibility='public' → mọi sale trong org dùng. 'private' → chỉ ownerUserId dùng.
// Phase 1 enforce parentId IS NULL ở route (1 cấp). Schema giữ parentId cho Phase 2.
model BlockFolder {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  visibility  String   @default("public") // 'public' | 'private' — 2026-06-04
  parentId    String?  @map("parent_id")
  ownerNickId String?  @map("owner_nick_id")
  ownerUserId String?  @map("owner_user_id")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org       Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent    BlockFolder?  @relation("BlockFolderNested", fields: [parentId], references: [id], onDelete: SetNull)
  children  BlockFolder[] @relation("BlockFolderNested")
  ownerNick ZaloAccount?  @relation("BlockFolderOwnerNick", fields: [ownerNickId], references: [id], onDelete: SetNull)
  ownerUser User?         @relation("BlockFolderOwnerUser", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy User          @relation("BlockFolderCreatedBy", fields: [createdById], references: [id])
  blocks    Block[]

  @@index([orgId, visibility])
  @@index([orgId, ownerNickId])
  @@index([orgId, ownerUserId])
  @@index([parentId])
  @@map("block_folders")
}

// Block — atomic content/action unit. ENTITY TRUNG TÂM:
// được Sequence.steps[].blockId, Broadcast.blockId, Trigger.blockId tham chiếu.
// `content` JSON shape theo `actionType`:
//   request_friend  → { greetingVariants: string[] }
//   send_message    → { textVariants: string[], attachments?: [{ kind, url, caption? }] }
//   update_status   → { statusId: string, condition?: {...} }
// `isShared`: false = chỉ owner dùng (block cá nhân của sale), true = mọi sale dùng.
// `usageCount` cache để UI hiện badge "đang dùng trong N sequence/broadcast".
// `archivedAt`: soft delete — block bị archive vẫn giữ snapshot trong task đang chạy.
model Block {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  folderId         String?   @map("folder_id")
  name             String
  channel          String    @default("zalo_user")
  actionType       String    @map("action_type") // 'request_friend' | 'send_message' | 'update_status' | ...
  content          Json      @default("{}")
  ownerNickId      String?   @map("owner_nick_id")
  // 2026-06-04: isShared DEPRECATED — visibility lên Folder. Giữ field để migrate dual-read 2 tuần.
  isShared         Boolean   @default(true) @map("is_shared")
  tagIds           String[]  @default([]) @map("tag_ids") // 2026-06-04 — dự án/mục đích, multi free-form
  usageCount       Int       @default(0) @map("usage_count")
  lastUsedAt       DateTime? @map("last_used_at")
  // 2026-06-07 — đếm RIÊNG số lần sale GỬI TAY Khối từ chat (KHÔNG tính automation/sequence).
  // usageCount gộp cả 2 nguồn; manualSendCount chỉ tăng ở endpoint /conversations/:id/send-block.
  manualSendCount  Int       @default(0) @map("manual_send_count")
  lastManualSentAt DateTime? @map("last_manual_sent_at")
  archivedAt       DateTime? @map("archived_at")
  createdById      String    @map("created_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  folder        BlockFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  ownerNick     ZaloAccount?   @relation("BlockOwnerNick", fields: [ownerNickId], references: [id], onDelete: SetNull)
  createdBy     User           @relation("BlockCreatedBy", fields: [createdById], references: [id])
  sequenceSteps SequenceStep[]
  // tasks  AutomationTask[]  ← REMOVED 2026-06-01 Luồng Mục Tiêu M0

  @@index([orgId, channel, actionType])
  @@index([orgId, archivedAt])
  @@index([folderId])
  @@index([tagIds], type: Gin)
  @@map("blocks")
}

// SequenceStep — 2026-06-04 Anh chốt: tách JSON blob ra table riêng.
// Trước: AutomationSequence.steps Json @default("[]") → archive Block silent break Sequence.
// Sau: FK Block thật. Worker dual-read: ưu tiên sequenceSteps[], fallback steps Json 2 tuần.
model SequenceStep {
  id            String   @id @default(uuid())
  sequenceId    String   @map("sequence_id")
  blockId       String?  @map("block_id") // nullable: step có thể chưa pick Block (draft)
  stepOrder     Int      @map("step_order")
  delayMinutes  Int      @default(0) @map("delay_minutes")
  // 2026-06-19 (gộp Luật 2 vào step) — jitter ± phút random quanh delayMinutes (chống bot). 0 = tắt.
  jitterMinutes Int      @default(0) @map("jitter_minutes")
  exitCondition Json?    @map("exit_condition") // {type: 'replied'|'clicked'|'timeout', value?}
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sequence AutomationSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  block    Block?             @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@unique([sequenceId, stepOrder])
  @@index([blockId])
  @@map("sequence_steps")
}

// Sequence — multi-step drip flow. `steps` là array có cấu trúc:
//   [{ stepId, blockId, delayMinutes, exitCondition? }, ...]
// Delay tính từ thời điểm step trước hoàn thành. delayMinutes=0 cho step đầu.
// `runtimeRules` (chốt từ memory):
//   { allowedHourRange: [6, 22],
//     randomDelayPerSend: { min: 15, max: 45 },
//     perNickThrottle: true,
//     crossNickRecencyDays: 30,
//     stopOnAccept: true }
model AutomationSequence {
  id                   String    @id @default(uuid())
  orgId                String    @map("org_id")
  name                 String
  description          String?
  channel              String    @default("zalo_user")
  steps                Json      @default("[]")
  runtimeRules         Json      @default("{}") @map("runtime_rules")
  // ── Stats Dashboard M10 cached counters (hồi sinh dead writer 2026-06-01) ──
  // Hooks: task-worker on state transition + friend-event-handler:502 REMOVE/BLOCK
  // + message-handler:557 customer_reply. Cron 02:30 VN reconcile drift từ raw aggregate.
  enrolledCount        Int       @default(0) @map("enrolled_count")
  completedCount       Int       @default(0) @map("completed_count")
  failedCount          Int       @default(0) @map("failed_count")
  blockCountCached     Int       @default(0) @map("block_count_cached")
  enrolledCountCached  Int       @default(0) @map("enrolled_count_cached")
  completedCountCached Int       @default(0) @map("completed_count_cached")
  replyCountCached     Int       @default(0) @map("reply_count_cached")
  countersLastSyncedAt DateTime? @map("counters_last_synced_at")
  enabled              Boolean   @default(true)
  createdById          String    @map("created_by_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  org           Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy     User                 @relation("SequenceCreatedBy", fields: [createdById], references: [id])
  triggers      AutomationTrigger[]  @relation("TriggerSequence")
  campaigns     AutomationCampaign[] @relation("CampaignSequence")
  sequenceSteps SequenceStep[] // 2026-06-04 — replace JSON `steps` (dual-read 2 weeks)

  @@index([orgId, channel, enabled])
  @@map("automation_sequences")
}

// Trigger — event-based entry catalog. Khi event `eventType` fire + match
// `eventFilter` + contact match `segmentSpec` → engine materialize 1 Campaign +
// tạo Task cho contact đó. `bindingKind` polymorphic: chỉ 1 trong 3 FK được set.
// `ruleOverrides` JSON: override sequence.runtimeRules tại trigger level
// (vd trigger sinh nhật chỉ chạy giờ 9-18).
model AutomationTrigger {
  id                      String    @id @default(uuid())
  orgId                   String    @map("org_id")
  name                    String
  category                String    @default("general") // 'general' | 'keyword' | 'bot_api' | 'livechat' | 'genai' | 'manual'
  eventType               String    @map("event_type")
  eventFilter             Json?     @map("event_filter")
  bindingKind             String    @map("binding_kind") // 'sequence' | 'block' | 'broadcast'
  sequenceId              String?   @map("sequence_id")
  blockId                 String?   @map("block_id")
  broadcastId             String?   @map("broadcast_id")
  segmentSpec             Json?     @map("segment_spec")
  ruleOverrides           Json?     @map("rule_overrides")
  enabled                 Boolean   @default(true)
  // Phase Friend Invite 2026-05-28 — successor sequence + greeting template
  successorSequenceId     String?   @map("successor_sequence_id")
  greetingTemplate        String?   @map("greeting_template") @db.Text
  // Wave 2 2026-05-29 — per-trigger welcome probe (split from Org-level)
  welcomeMessageTemplate  String?   @map("welcome_message_template") @db.Text
  // FIX 2026-06-08 (Anh chốt): default 60→1. Sàn welcomeMinFloorSeconds đã bỏ khỏi
  // welcome-probe → độ trễ welcome = ĐÚNG giá trị này. Anh chỉnh khi tạo trigger.
  welcomeDelaySeconds     Int       @default(1) @map("welcome_delay_seconds")
  // ── Cấu trúc 5 tin 2026-06-04 (I10 — Anh chốt qua /design-html) ──
  // Tin 2 · Cảm ơn KH đã đồng ý KB — gửi khi event friend_accepted (KHÁC welcome=Tin1
  // gửi sau khi mời, không chờ accept). thankYouDelay tính từ lúc KH accept.
  thankYouTemplate        String?   @map("thank_you_template") @db.Text
  thankYouDelaySeconds    Int       @default(60) @map("thank_you_delay_seconds")
  // Tin 3 · Nhắc KH đồng ý KB sau N ngày (cron quét, tự bỏ qua nếu đã accept).
  remindTemplate          String?   @map("remind_template") @db.Text
  remindDelayDays         Int       @default(3) @map("remind_delay_days")
  // Tin 4 · Khi KH từ chối KB — gửi qua hộp người lạ ngay khi event friend_rejected.
  rejectedTemplate        String?   @map("rejected_template") @db.Text
  // 4 cờ bật/tắt từng tin (Lời mời = greetingTemplate luôn bắt buộc, không có cờ).
  // Tin 1 Chào mừng / Tin 2 Cảm ơn / Tin 3 Nhắc / Tin 4 Từ chối.
  enableWelcome           Boolean   @default(true) @map("enable_welcome")
  enableThankYou          Boolean   @default(true) @map("enable_thank_you")
  enableRemind            Boolean   @default(true) @map("enable_remind")
  enableRejectedFollowUp  Boolean   @default(false) @map("enable_rejected_follow_up")
  // ── #1 2026-06-06 (Anh chốt): 2 công tắc bám đuổi theo trạng thái kết bạn ──
  // followUpStrangerEnabled: bám đuổi cả khi KH CHƯA đồng ý kết bạn (gửi qua hộp
  //   người lạ). BẬT = hành vi cũ (spam hết luồng). TẮT = chỉ bám đuổi sau khi accept.
  // followUpFriendEnabled: bám đuổi khi KH ĐÃ là bạn — kích hoạt khi nhận event
  //   accept thật từ Zalo (onFriendAccepted). TẮT = KH duyệt cũng không bám đuổi.
  // Default cả 2 = true → Mục tiêu cũ giữ nguyên hành vi.
  followUpStrangerEnabled Boolean   @default(true) @map("follow_up_stranger_enabled")
  followUpFriendEnabled   Boolean   @default(true) @map("follow_up_friend_enabled")
  // ── Tự đặt tên gợi nhớ (Zalo alias) 2026-06-19 (Anh chốt) ──
  // changeFriendAlias(alias, friendId=UID) KHÔNG cần friendship → đặt NGAY khi findUser ra
  // UID trong request_friend, cho TOÀN BỘ tệp có Zalo ("đặt hết"). LUÔN ĐÈ theo mẫu.
  // aliasTemplate dùng biến render-template (vd {zalo_name} {trigger_project} {income} {phone}).
  // {zalo_name}=tên Zalo THẬT (CEO chốt, ko phải tên import). {trigger_project}=projectAbbr.
  autoAliasEnabled        Boolean   @default(false) @map("auto_alias_enabled")
  aliasTemplate           String?   @map("alias_template") @db.Text
  projectAbbr             String?   @map("project_abbr")
  // Thông báo nội bộ per-event: { "<eventKey>": { "owner": bool, "manager": bool, "zaloGroup": bool } }
  // eventKey: welcome|thankYou|remind|rejected|reply|reactionPositive|reactionNegative|lead|block|friendAccept|friendReject.
  // owner = Sale phụ trách nick (LÀM THẬT). manager auto org-tree (RBAC M2). zaloGroup = UID nhập Settings.
  notifyChannels          Json?     @map("notify_channels")
  // ── CareSession (Phiên chăm sóc) 2026-06-07 — điều kiện ĐÓNG phiên per-Mục-tiêu ──
  // { onStatusIds: [...], onFriendTagIds: [...], onCrmTagIds: [...], silenceDays: 7 }
  // Snapshot vào CareSession.closeConditions khi tạo phiên → khách ở 2 Mục tiêu áp 2 luật riêng.
  closeConditions         Json?     @map("close_conditions")
  state                   String    @default("draft") // 'draft' | 'active' | 'paused' | 'cancelling' | 'cancelled' | 'completed' (UI derive 'scheduled' khi state=draft + scheduledAt set)
  // BE T4 2026-05-30 — friend-invite lên lịch hẹn giờ. NULL = activate ngay khi gọi /activate.
  scheduledAt             DateTime? @map("scheduled_at")
  // P2 Wave 4 2026-06-02 — Tạm dừng có thời hạn. NULL = pause vô hạn (user phải bấm "Tiếp tục").
  // Set khi gọi /pause với body { ttlHours }. Cron sweep mỗi 1 phút auto-flip state='paused'→'active'
  // khi pausedUntil <= NOW() (đồng thời reset pausedUntil=NULL).
  pausedUntil             DateTime? @map("paused_until")

  // ── Luồng Mục Tiêu rebuild 2026-06-01 (Marketing BullMQ Rebuild M0) ──
  // P1: Delay sau khi gửi lời mời → step 1 bám đuổi (phút). Cấu hình per-trigger qua Wizard B3.
  sequenceStartDelayMinutes   Int     @default(60) @map("sequence_start_delay_minutes")
  // 2026-06-16 — bản GIÂY của delay trên (Wizard B3 cho nhập giây, mặc định 10s).
  // NULL = Mục tiêu cũ chưa cấu hình giây → fallback sequence_start_delay_minutes × 60.
  // Mọi consumer ưu tiên cột này khi != NULL. 0 = gửi ngay (không delay).
  sequenceStartDelaySeconds   Int?    @map("sequence_start_delay_seconds")
  // P2: Pause khi KH tương tác (giờ). Reply trong window → reset (P2.1).
  pauseOnActivityHours        Int     @default(24) @map("pause_on_activity_hours")
  // P6: Bỏ qua KH có > N nick friend trong hệ thống (0 = không filter, JOIN permission_groups theo T3A).
  multiNickThreshold          Int     @default(0) @map("multi_nick_threshold")
  // D12: Concurrency per nick per minute.
  concurrencyPerNickPerMinute Int     @default(1) @map("concurrency_per_nick_per_minute")
  // Working hours VN (giờ 0-23). Cap đọc từ ZaloAccount per-nick (KHÔNG duplicate ở trigger).
  sendHourStart               Int     @default(6) @map("send_hour_start")
  sendHourEnd                 Int     @default(22) @map("send_hour_end")
  // Cross-nick recency: skip KH tương tác nick khác < N ngày (0 = không filter).
  recencySkipDays             Int     @default(30) @map("recency_skip_days")
  // Per-nick throttle gate (ms) giữa các lần gửi friend-request.
  minFriendReqGapMs           Int     @default(60000) @map("min_friend_req_gap_ms")
  // ── #3 2026-06-06 (Anh chốt): đưa nhịp gửi + sàn welcome + cửa sổ warm RA UI ──
  // Trước đây nick-worker.getRandomDelayMs() HARDCODE 20-40 phút (hoặc 1 phút khi
  // FRIEND_INVITE_TEST_MODE) và PHỚT LỜ ô user nhập. Giờ worker đọc 2 cột này:
  // nhịp gửi 1 lời mời/nick = random trong [min, max] phút. Đặt min=max để cố định.
  // Default 20-40 = giữ nguyên hành vi prod cũ; muốn "test nhanh" thì set min=max=1.
  friendReqIntervalMinMinutes Int     @default(20) @map("friend_req_interval_min_minutes")
  friendReqIntervalMaxMinutes Int     @default(40) @map("friend_req_interval_max_minutes")
  // DEPRECATED 2026-06-08 (Anh chốt bỏ sàn): welcome-probe KHÔNG còn dùng cột này.
  // Trước đây độ trễ = MAX(sàn, welcomeDelaySeconds) → ép tối thiểu 60s. Giờ độ trễ =
  // ĐÚNG welcomeDelaySeconds. Cột giữ lại để tránh migration drop, không tham chiếu nữa.
  welcomeMinFloorSeconds      Int     @default(60) @map("welcome_min_floor_seconds")
  // Cửa sổ (ngày) coi KH là "ấm" (đã là bạn + có inbound gần đây) để gửi Tin 1 qua
  // kênh bạn bè thay vì hộp người lạ — trước đây hardcode 30 ngày ở welcome-probe.
  warmWindowDays              Int     @default(30) @map("warm_window_days")
  // Memory 1-1 only (feedback_crm_filter_1to1_not_group) — chỉ trigger conv.threadType='user'.
  filterThreadType            String  @default("user") @map("filter_thread_type")
  // M9 System trigger flag — "Bám đuổi khách hàng thủ công" KHÔNG cho xoá, chỉ Tắt.
  isSystemTrigger             Boolean @default(false) @map("is_system_trigger")
  systemKind                  String? @map("system_kind") // 'manual_chat_followup' | future kinds

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org          Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sequence     AutomationSequence?  @relation("TriggerSequence", fields: [sequenceId], references: [id], onDelete: SetNull)
  broadcast    AutomationBroadcast? @relation("TriggerBroadcast", fields: [broadcastId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("TriggerCreatedBy", fields: [createdById], references: [id])
  campaigns    AutomationCampaign[] @relation("CampaignTrigger")
  // #2 2026-06-06 — hàng đợi per-trigger (mỗi Mục tiêu độc lập, không tranh khách).
  queueEntries TriggerQueueEntry[]
  // CareSession 2026-06-07 — phiên chăm sóc sinh từ trigger này.
  careSessions CareSession[]

  @@index([orgId, eventType, enabled])
  @@index([orgId, category])
  // Wave 2 cron sweep — scheduled_at activate
  @@index([state, scheduledAt])
  // P2 Wave 4 2026-06-03 — auto-resume sweeper picks paused triggers whose TTL is due.
  @@index([state, pausedUntil])
  // M9 — quick lookup system trigger per org
  @@index([systemKind])
  @@map("automation_triggers")
}

// Broadcast — one-shot mass send. 1 broadcast = 1 block + 1 segment + schedule.
// `pacing` áp dụng rate limit per nick (memory: project_zalocrm_rate_limits):
//   { distributeAcrossNicks: true,
//     maxPerNickPerHour: 50,           ← dưới cap 300 msg/day/nick
//     allowedHourRange: [6, 22],
//     randomDelayBetweenSends: { min: 15, max: 45 } }
model AutomationBroadcast {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  name            String
  description     String?
  channel         String    @default("zalo_user")
  blockId         String    @map("block_id")
  segmentSpec     Json      @map("segment_spec")
  scheduleKind    String    @default("now") @map("schedule_kind") // 'now' | 'scheduled' | 'recurring'
  scheduledAt     DateTime? @map("scheduled_at")
  recurringSpec   Json?     @map("recurring_spec")
  pacing          Json      @default("{}")
  state           String    @default("draft") // 'draft' | 'scheduled' | 'running' | 'paused' | 'completed' | 'cancelled'
  totalRecipients Int       @default(0) @map("total_recipients")
  sentCount       Int       @default(0) @map("sent_count")
  deliveredCount  Int       @default(0) @map("delivered_count")
  failedCount     Int       @default(0) @map("failed_count")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdById     String    @map("created_by_id")

  // Broadcasts Đợt 1 (2026-06-05): worker E2E + resume cursor.
  // resumeCursor = last sent contactId — worker pause/resume picks up where it left off.
  resumeCursor String? @map("resume_cursor")
  // workerStats — Json blob worker tự ghi: { perNickSent: { nickId: count }, lastTickAt, lastError, ... }
  workerStats  Json?   @map("worker_stats")
  // variantSpec / abTestStats — placeholder for Đợt 2 A/B test. Đợt 1 chưa dùng.
  variantSpec  Json?   @map("variant_spec")
  abTestStats  Json?   @map("ab_test_stats")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org       Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User                 @relation("BroadcastCreatedBy", fields: [createdById], references: [id])
  triggers  AutomationTrigger[]  @relation("TriggerBroadcast")
  campaigns AutomationCampaign[] @relation("CampaignBroadcast")

  @@index([orgId, channel, state])
  @@index([scheduledAt])
  @@map("automation_broadcasts")
}

// AutomationCampaign — runtime materialize của Trigger hoặc Broadcast.
// 1 Trigger có thể sinh nhiều Campaign (mỗi lần event fire một batch).
// 1 Broadcast = 1 Campaign khi state chuyển running.
// `segmentSnapshot` chốt contact IDs tại activation (hoặc live re-resolve nếu cần).
// `rulesSnapshot` frozen runtimeRules → task chạy trong campaign này dùng snapshot
// này, không bị ảnh hưởng nếu Sequence.runtimeRules edit sau.
model AutomationCampaign {
  id                 String    @id @default(uuid())
  orgId              String    @map("org_id")
  triggerId          String?   @map("trigger_id")
  broadcastId        String?   @map("broadcast_id")
  executionKind      String    @map("execution_kind") // 'sequence' | 'single_block' | 'broadcast'
  sequenceId         String?   @map("sequence_id")
  blockId            String?   @map("block_id")
  segmentSnapshot    Json      @map("segment_snapshot")
  rulesSnapshot      Json      @map("rules_snapshot")
  state              String    @default("active") // 'active' | 'paused' | 'completed' | 'cancelled' | 'on_hold' | 'timeout'
  activatedAt        DateTime  @default(now()) @map("activated_at")
  completedAt        DateTime? @map("completed_at")
  // ── Sticky Nick 24h Hold (Sprint v3 2026-06-03) ──
  // Mốc nick sticky của campaign offline lần đầu. Sequence-step worker SET
  // khi gặp nick.status != connected → flip campaign state='on_hold' +
  // moveToDelayed(30 phút). Sweeper sticky-hold đọc để compute 23h timeout.
  // Reset NULL khi nick hồi → state='active'.
  nickFirstOfflineAt DateTime? @map("nick_first_offline_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  org       Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trigger   AutomationTrigger?   @relation("CampaignTrigger", fields: [triggerId], references: [id], onDelete: SetNull)
  broadcast AutomationBroadcast? @relation("CampaignBroadcast", fields: [broadcastId], references: [id], onDelete: SetNull)
  sequence  AutomationSequence?  @relation("CampaignSequence", fields: [sequenceId], references: [id], onDelete: SetNull)
  // tasks    AutomationTask[]  ← REMOVED 2026-06-01 (Luồng Mục Tiêu M0)
  //                              AutomationTask đã drop, BullMQ làm runtime layer

  @@index([orgId, state])
  @@index([triggerId, state])
  @@index([broadcastId, state])
  @@map("automation_campaigns")
}

// ════════════════════════════════════════════════════════════════════════
// AutomationTask model REMOVED — Luồng Mục Tiêu M0 (2026-06-01)
// Lý do: BullMQ + Redis làm runtime layer thay thế DB polling.
// Code đụng prisma.automationTask đã stub trong M0, rewrite trong M2-M4 với queue.
// Pattern jobId: ${triggerId}-${contactId}-${stepIdx} (DASH, BullMQ v5 cấm `:`).
