// MessageTemplate — câu mẫu sale gửi tay trong chat (gõ "/" để chèn).
// 2026-06-09 (Anh chốt) NÂNG CẤP đồng bộ Khối: thêm folder + visibility per-item +
// tagIds (4 tag dự án) + contentRich {text, styles[]} (định dạng Zalo: đậm/màu/cỡ).
// Cơ chế quyền GỘP CHUNG resource 'block' + mô hình "là chủ HOẶC có grant":
//   chủ (createdById) tạo/sửa mẫu RIÊNG của mình KHÔNG cần grant; đăng CÔNG KHAI cần grant block.create.
// `content` (plain) LUÔN derive = contentRich.text ở route (dùng search + chèn chat).
// `ownerUserId` LEGACY (null=team cũ): giữ dual-read, migrate → visibility+createdById.
model MessageTemplate {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  ownerUserId      String?   @map("owner_user_id") // LEGACY: null=team. Giữ migrate dual-read.
  folderId         String?   @map("folder_id")
  // visibility cho mẫu LẺ (folderId=null). Mẫu trong folder kế thừa folder.visibility.
  // Default 'private' (an toàn — anh chốt mặc định Riêng tư cho mẫu mới).
  visibility       String    @default("private") // 'public' | 'private'
  name             String
  // Từ khóa gõ tắt — sale gõ "/giaEGV" nhảy đúng mẫu (giống shortcut Zalo/Telegram).
  // Lowercase không dấu cách. Popup match prefix theo shortcut TRƯỚC, rồi tên/nội dung.
  shortcut         String?
  content          String // plain text — LUÔN = contentRich.text (derive ở route), dùng search + chèn chat
  contentRich      Json?     @map("content_rich") // { text: string, styles: [{st,start,len}] } — định dạng Zalo
  category         String? // phân loại chức năng (FAQ/Chào/Chốt) — song song tagIds dự án
  tagIds           String[]  @default([]) @map("tag_ids") // 4 tag dự án + free-form
  usageCount       Int       @default(0) @map("usage_count")
  lastUsedAt       DateTime? @map("last_used_at")
  manualSendCount  Int       @default(0) @map("manual_send_count")
  lastManualSentAt DateTime? @map("last_manual_sent_at")
  archivedAt       DateTime? @map("archived_at") // soft delete
  createdById      String?   @map("created_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  org       Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner     User?                  @relation(fields: [ownerUserId], references: [id])
  folder    MessageTemplateFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdBy User?                  @relation("MessageTemplateCreatedBy", fields: [createdById], references: [id])

  @@index([orgId, ownerUserId])
  @@index([orgId, category])
  @@index([orgId, folderId])
  @@index([orgId, visibility])
  @@index([orgId, archivedAt])
  @@index([orgId, shortcut])
  @@index([tagIds], type: Gin)
  @@map("message_templates")
}

// MessageTemplateFolder — nhóm thư mục cho Mẫu tin nhắn (copy y BlockFolder).
// visibility='public' → mọi sale org dùng; 'private' → chỉ ownerUserId.
// Phase 1 enforce parentId IS NULL ở route (1 cấp). Schema giữ parentId cho Phase 2.
model MessageTemplateFolder {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  visibility  String   @default("public") // 'public' | 'private'
  parentId    String?  @map("parent_id")
  ownerUserId String?  @map("owner_user_id")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org       Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent    MessageTemplateFolder?  @relation("MTFolderNested", fields: [parentId], references: [id], onDelete: SetNull)
  children  MessageTemplateFolder[] @relation("MTFolderNested")
  ownerUser User?                   @relation("MTFolderOwnerUser", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy User                    @relation("MTFolderCreatedBy", fields: [createdById], references: [id])
  templates MessageTemplate[]

  @@index([orgId, visibility])
  @@index([orgId, ownerUserId])
  @@index([parentId])
  @@map("message_template_folders")
}

model AiConfig {
  id                          String   @id @default(uuid())
  orgId                       String   @unique @map("org_id")
  provider                    String   @default("anthropic")
  model                       String   @default("claude-sonnet-4-6")
  maxDaily                    Int      @default(500) @map("max_daily")
  enabled                     Boolean  @default(true)
  // M53 (2026-05-30): AI Trợ Lý cho Virtual Chat. Anh edit promptTemplate qua /settings/crm/ai-assistant.
  // Default skip regex: "ok", "uhm", "ờ" — tránh gọi AI cho tin nhắn noise.
  aiAssistantEnabled          Boolean  @default(true) @map("ai_assistant_enabled")
  aiAssistantPromptTemplate   String?  @map("ai_assistant_prompt_template") @db.Text
  aiAssistantSkipNoisePattern String   @default("^(ok|oke|okay|uhm|um|ờ|à|ừ|a|o|yes|no|y|n|\\.|\\.\\.|\\.\\.\\.)\\s*$") @map("ai_assistant_skip_noise_pattern")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

// M53 (2026-05-30): Audit log mỗi lần sale click "Áp dụng" trên AiSuggestionCard.
// Lưu acceptedFields để track AI accuracy + replay nếu cần undo.
model AiSuggestionApplied {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  contactId      String   @map("contact_id")
  messageId      String   @map("message_id") // FK Message chứa AI suggestion (metadata.extracted)
  userId         String   @map("user_id") // sale đã apply
  acceptedFields Json     @map("accepted_fields") // [{field, oldValue, newValue}]
  rejectedFields Json?    @map("rejected_fields") // optional, học pattern
  createdAt      DateTime @default(now()) @map("created_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])

  @@index([orgId, contactId])
  @@index([orgId, createdAt])
  @@map("ai_suggestions_applied")
}

model AiSuggestion {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  // 2026-05-28: nullable cho AI tasks không gắn conv cụ thể (format-rich, sales-handoff,
  // lead-pool suggestions). Trước fix: FK violated → catch swallow → quota counter sai.
  conversationId String?  @map("conversation_id")
  messageId      String?  @map("message_id")
  type           String
  content        String
  confidence     Float
  accepted       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([conversationId, createdAt])
  @@index([orgId, type, createdAt])
  @@map("ai_suggestions")
}

// ── Ported from openzca ────────────────────────────────────────────────────

// Emoji reaction on a message (ported from openzca msg react)
// reactorId có 2 nguồn: CRM User.id (khi nhân viên CRM thả qua route) hoặc Zalo UID
// (khi sync từ Zalo client qua listener). Phân biệt qua reactorSource.
model MessageReaction {
  id            String   @id @default(uuid())
  messageId     String   @map("message_id")
  reactorId     String   @map("reactor_id") // CRM user.id hoặc Zalo UID — xem reactorSource
  reactorSource String   @default("crm") @map("reactor_source") // "crm" | "zalo"
  reactorName   String?  @map("reactor_name")
  emoji         String // ❤️ 👍 😆 😮 😭 😡 — hoặc raw Zalo code khi sync
  createdAt     DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Cho phép multi-emoji: 1 user (CRM hoặc Zalo) có thể thả nhiều emoji khác nhau trên cùng tin.
  @@unique([messageId, reactorId, emoji])
  @@index([messageId])
  @@map("message_reactions")
