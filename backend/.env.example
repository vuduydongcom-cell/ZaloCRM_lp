PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

# openssl rand -hex 32
JWT_SECRET=
# openssl rand -hex 32
ENCRYPTION_KEY=

DB_USER=crmuser
# PostgreSQL password
DB_PASSWORD=
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm

UPLOAD_DIR=/var/lib/zalo-crm/files

# MinIO local / S3-compatible storage
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_BUCKET=zalocrm-attachments
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Cloudflare R2 example
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://<public-r2-domain-or-custom-domain>
# S3_BUCKET=zalocrm-attachments
# S3_REGION=auto
# S3_ACCESS_KEY=<r2-access-key-id>
# S3_SECRET_KEY=<r2-secret-access-key>

AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Facebook Lead Ads (tùy chọn) ---
FB_GRAPH_API_VERSION=v21.0
# App ID + Secret từ developers.facebook.com (App → Settings → Basic)
FB_APP_ID=
FB_APP_SECRET=
# Verify token webhook (tự đặt, khớp cấu hình Meta). openssl rand -hex 16
FB_WEBHOOK_VERIFY_TOKEN=
# Khoá mã hoá token tích hợp (FB page token...) lưu DB — 64 hex. BẮT BUỘC nếu dùng FB
# (app throw nếu thiếu). openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
# Thay domain production
FB_OAUTH_REDIRECT_URI=https://your-domain.com/api/v1/integrations/facebook/oauth/callback

# --- Bảo mật nâng cấp: Token / Tenant / CSP (tùy chọn — đều có default) ---
# Tuổi access token (rút ngắn vd 5m để thu hồi nhanh hơn). Default 15m
ACCESS_TOKEN_TTL=15m
# Tuổi refresh token (ms) sliding. Default 30 ngày
REFRESH_TOKEN_TTL_MS=2592000000
# Tuổi tuyệt đối 1 phiên (ms) — không vượt dù xoay liên tục. Default 90 ngày
REFRESH_FAMILY_MAX_MS=7776000000
# Grace window (ms) chống race đa tab khi refresh. Default 20000
REFRESH_GRACE_MS=20000
# Cô lập tenant tầng app: off (default) | warn (log trên staging) | enforce (chặn, sau khi apply RLS)
TENANT_GUARD_MODE=off
# Content-Security-Policy: report-only (default) | enforce | off. Host ws tự suy từ APP_URL
CSP_MODE=report-only
# true = socket từ chối token legacy (bật SAU cutover). Default false
SOCKET_REQUIRE_ACCESS_TYP=false
# true = gắn app.current_org vào connection cho Postgres RLS (SET LOCAL). Default false.
# Chỉ bật trên staging SAU khi apply tenant-rls.sql + role app NOSUPERUSER.
RLS_SET_CONFIG=false
